package main

import (
	"errors"
	"os"
	"path/filepath"
	"regexp"
	"strings"
)

func handleFs(id, workspace, cwd, kind string, op any) error {
	switch kind {
	case "fs.list":
		return handleFsList(id, workspace, cwd, op)
	case "fs.stat":
		return handleFsStat(id, workspace, cwd, op)
	case "fs.read":
		return handleFsRead(id, workspace, cwd, op)
	case "fs.readMany":
		return handleFsReadMany(id, workspace, cwd, op)
	case "fs.grep":
		return handleFsGrep(id, workspace, cwd, op)
	case "fs.write":
		return handleFsWrite(id, workspace, cwd, op)
	case "fs.mkdir":
		return handleFsMkdir(id, workspace, cwd, op)
	case "fs.remove":
		return handleFsRemove(id, workspace, cwd, op)
	case "fs.rename":
		return handleFsRename(id, workspace, cwd, op)
	case "fs.copy":
		return handleFsCopy(id, workspace, cwd, op)
	default:
		writeError(id, "ERR_NOT_SUPPORTED", "unknown fs op: "+kind)
		return nil
	}
}

// resolvePathParam extracts a string path field from op by key, resolves it to an
// absolute sandbox-checked path, and writes an error response if anything fails.
// Returns ("", false) on failure so the caller can do: abs, ok := resolvePathParam(...); if !ok { return nil }
func resolvePathParam(id, workspace, cwd string, op any, key string) (string, bool) {
	pathAny, err := op~>[key]
	if err != nil {
		writeError(id, "ERR_INTERNAL", "missing required field: "+key)
		return "", false
	}
	path, ok := pathAny.(string)
	if !ok {
		writeError(id, "ERR_INTERNAL", "field "+key+" must be a string")
		return "", false
	}
	abs, sandboxErr := resolveAndSandbox(workspace, cwd, path)
	if sandboxErr != nil {
		writeError(id, "ERR_ACCESS_DENIED", sandboxErr.Error())
		return "", false
	}
	return abs, true
}

// resolveAndSandbox resolves path to absolute, then verifies it is within workspace.
func resolveAndSandbox(workspace, cwd, path string) (string, error) {
	var abs string
	if filepath.IsAbs(path) {
		abs = filepath.Clean(path)
	} else {
		abs = filepath.Join([]string{cwd, path})
	}
	if !strings.HasPrefix(abs, workspace) {
		return "", errors.New("path outside workspace: " + abs)
	}
	return abs, nil
}

func handleFsList(id, workspace, cwd string, op any) error {
	abs, ok := resolvePathParam(id, workspace, cwd, op, "path")
	if !ok {
		return nil
	}

	entries, err := os.ReadDir(abs)
	if err != nil {
		writeError(id, fsErrCode(err), err.Error())
		return nil
	}

	result := make([]map[string]any, 0, len(entries))
	for _, e := range entries {
		result = append(result, map[string]any{
			"name":  e.Name(),
			"path":  abs + "/" + e.Name(),
			"isDir": e.IsDir(),
		})
	}
	writeOk(id, result)
	return nil
}

func handleFsStat(id, workspace, cwd string, op any) error {
	abs, ok := resolvePathParam(id, workspace, cwd, op, "path")
	if !ok {
		return nil
	}

	info, err := os.Stat(abs)
	if err != nil {
		writeError(id, fsErrCode(err), err.Error())
		return nil
	}

	writeOk(id, map[string]any{
		"name":  info.Name(),
		"path":  abs,
		"isDir": info.IsDir(),
		"size":  info.Size(),
	})
	return nil
}

func handleFsRead(id, workspace, cwd string, op any) error {
	abs, ok := resolvePathParam(id, workspace, cwd, op, "path")
	if !ok {
		return nil
	}

	data, err := os.ReadFile(abs)
	if err != nil {
		writeError(id, fsErrCode(err), err.Error())
		return nil
	}

	writeOk(id, string(data))
	return nil
}

func handleFsWrite(id, workspace, cwd string, op any) error {
	abs, ok := resolvePathParam(id, workspace, cwd, op, "path")
	if !ok {
		return nil
	}
	var content string
	content = op~>content?

	err := os.WriteFile(abs, []byte(content), 0644)
	if err != nil {
		writeError(id, fsErrCode(err), err.Error())
		return nil
	}
	writeOk(id, nil)
	return nil
}

func handleFsMkdir(id, workspace, cwd string, op any) error {
	abs, ok := resolvePathParam(id, workspace, cwd, op, "path")
	if !ok {
		return nil
	}

	err := os.MkdirAll(abs, 0755)
	if err != nil {
		writeError(id, fsErrCode(err), err.Error())
		return nil
	}
	writeOk(id, nil)
	return nil
}

func handleFsRemove(id, workspace, cwd string, op any) error {
	abs, ok := resolvePathParam(id, workspace, cwd, op, "path")
	if !ok {
		return nil
	}

	recursiveAny, _ := op~>recursive
	recursive, _ := recursiveAny.(bool)

	var err error
	if recursive {
		err = os.RemoveAll(abs)
	} else {
		err = os.Remove(abs)
	}
	if err != nil {
		writeError(id, fsErrCode(err), err.Error())
		return nil
	}
	writeOk(id, nil)
	return nil
}

func handleFsRename(id, workspace, cwd string, op any) error {
	absOld, ok := resolvePathParam(id, workspace, cwd, op, "oldPath")
	if !ok {
		return nil
	}
	absNew, ok2 := resolvePathParam(id, workspace, cwd, op, "newPath")
	if !ok2 {
		return nil
	}

	err := os.Rename(absOld, absNew)
	if err != nil {
		writeError(id, fsErrCode(err), err.Error())
		return nil
	}
	writeOk(id, nil)
	return nil
}

func handleFsCopy(id, workspace, cwd string, op any) error {
	absSrc, ok := resolvePathParam(id, workspace, cwd, op, "src")
	if !ok {
		return nil
	}
	absDst, ok2 := resolvePathParam(id, workspace, cwd, op, "dst")
	if !ok2 {
		return nil
	}

	info, err := os.Stat(absSrc)
	if err != nil {
		writeError(id, fsErrCode(err), err.Error())
		return nil
	}

	if info.IsDir() {
		err = copyDir(absSrc, absDst)
	} else {
		err = copyFile(absSrc, absDst)
	}
	if err != nil {
		writeError(id, fsErrCode(err), err.Error())
		return nil
	}
	writeOk(id, nil)
	return nil
}

func copyFile(src, dst string) error {
	data, err := os.ReadFile(src)
	if err != nil {
		return err
	}
	return os.WriteFile(dst, data, 0644)
}

func copyDir(src, dst string) error {
	err := os.MkdirAll(dst, 0755)
	if err != nil {
		return err
	}
	entries, err := os.ReadDir(src)
	if err != nil {
		return err
	}
	for _, e := range entries {
		srcPath := src + "/" + e.Name()
		dstPath := dst + "/" + e.Name()
		if e.IsDir() {
			err = copyDir(srcPath, dstPath)
		} else {
			err = copyFile(srcPath, dstPath)
		}
		if err != nil {
			return err
		}
	}
	return nil
}

// fsErrCode maps an error string to a ShellErrorCode.
func fsErrCode(err error) string {
	msg := err.Error()
	switch {
	case strings.Contains(msg, "no such file") || strings.Contains(msg, "not exist"):
		return "ERR_NOT_FOUND"
	case strings.Contains(msg, "permission denied"):
		return "ERR_ACCESS_DENIED"
	case strings.Contains(msg, "already exists") || strings.Contains(msg, "file exists"):
		return "ERR_ALREADY_EXISTS"
	default:
		return "ERR_INTERNAL"
	}
}

func handleFsReadMany(id, workspace, cwd string, op any) error {
	var paths []string
	paths = op~>paths?

	results := make([]map[string]any, 0, len(paths))
	for _, p := range paths {
		abs, err := resolveAndSandbox(workspace, cwd, p)
		if err != nil {
			results = append(results, map[string]any{"path": p, "error": err.Error()})
			continue
		}
		data, err := os.ReadFile(abs)
		if err != nil {
			results = append(results, map[string]any{"path": p, "error": err.Error()})
			continue
		}
		results = append(results, map[string]any{"path": p, "content": string(data)})
	}
	writeOk(id, results)
	return nil
}

func handleFsGrep(id, workspace, cwd string, op any) error {
	var pattern string
	pattern = op~>pattern?

	recursiveAny, _ := op~>recursive
	recursive, _ := recursiveAny.(bool)

	caseAny, _ := op~>caseInsensitive
	caseInsensitive, _ := caseAny.(bool)

	fixedAny, _ := op~>fixedString
	fixedString, _ := fixedAny.(bool)

	abs, ok := resolvePathParam(id, workspace, cwd, op, "path")
	if !ok {
		return nil
	}

	pat := pattern
	if fixedString {
		pat = regexp.QuoteMeta(pat)
	}
	if caseInsensitive {
		pat = "(?i)" + pat
	}

	info, err := os.Stat(abs)
	if err != nil {
		writeError(id, fsErrCode(err), err.Error())
		return nil
	}

	var matches []map[string]any
	if info.IsDir() {
		if !recursive {
			writeError(id, "ERR_INTERNAL", "path is a directory — use recursive: true")
			return nil
		}
		matches, err = grepDir(pat, abs)
	} else {
		matches, err = grepFile(pat, abs)
	}
	if err != nil {
		writeError(id, "ERR_INTERNAL", err.Error())
		return nil
	}
	writeOk(id, matches)
	return nil
}

func grepDir(pattern, dirPath string) ([]map[string]any, error) {
	entries, err := os.ReadDir(dirPath)
	if err != nil {
		return nil, err
	}
	results := []map[string]any{}
	for _, e := range entries {
		p := dirPath + "/" + e.Name()
		if e.IsDir() {
			sub, _ := grepDir(pattern, p)
			results = append(results, sub...)
		} else {
			sub, _ := grepFile(pattern, p)
			results = append(results, sub...)
		}
	}
	return results, nil
}

func grepFile(pattern, filePath string) ([]map[string]any, error) {
	data, err := os.ReadFile(filePath)
	if err != nil {
		return nil, err
	}
	lines := strings.Split(string(data), "\n")
	results := []map[string]any{}
	for i, line := range lines {
		matched, matchErr := regexp.MatchString(pattern, line)
		if matchErr != nil {
			return nil, matchErr
		}
		if matched {
			results = append(results, map[string]any{
				"path": filePath,
				"line": i + 1,
				"text": line,
			})
		}
	}
	return results, nil
}
