{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@examples/*": ["../examples/*"],
      "@vogui/*": ["../../vogui/js/src/*"],
      "preact": ["../../vogui/js/node_modules/preact"],
      "preact/*": ["../../vogui/js/node_modules/preact/*"],
      "react": ["../../vogui/js/node_modules/preact/compat"],
      "react-dom": ["../../vogui/js/node_modules/preact/compat"],
      "react/jsx-runtime": ["../../vogui/js/node_modules/preact/jsx-runtime"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
