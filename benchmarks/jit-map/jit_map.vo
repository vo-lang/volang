package main

func main() {
	n := 200000
	m := make(map[int]int)
	sum := 0

	for i := 0; i < n; i++ {
		m[i] = i * 3
	}
	for i := 0; i < n; i++ {
		if v, ok := m[i]; ok {
			sum += v
		}
	}
	for i := 0; i < n; i += 2 {
		delete(m, i)
	}
	for i := 1; i < n; i += 2 {
		sum += m[i]
	}

	println(sum)
}
