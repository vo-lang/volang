package main

type Adder interface {
	Add(int) int
}

type Inc struct {
	base int
}

func (i *Inc) Add(x int) int {
	return x + i.base
}

func direct(x int) int {
	return x + 7
}

func makeAdder(base int) func(int) int {
	return func(x int) int {
		return x + base
	}
}

func main() {
	n := 1000000
	sum := 0
	f := makeAdder(5)
	var adder Adder = &Inc{base: 9}

	for i := 0; i < n; i++ {
		x := i & 1023
		sum += direct(x)
		sum += f(x)
		sum += adder.Add(x)
	}

	println(sum)
}
