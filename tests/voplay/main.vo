package main

import (
	"fmt"
	"github.com/vo-lang/voplay"
)

func main() {
	testMathTypes()
	testColor()
	testColliders()
	testSceneBasics()
	fmt.Println("All voplay tests passed.")
}

func testMathTypes() {
	// Vec2
	a := voplay.Vec2{3, 4}
	assert(a.Length() == 5.0, "Vec2.Length")
	b := voplay.Vec2{1, 0}
	c := a.Add(b)
	assert(c.X == 4 && c.Y == 4, "Vec2.Add")

	n := a.Normalize()
	assert(n.X == 0.6 && n.Y == 0.8, "Vec2.Normalize")

	// Vec3
	v := voplay.Vec3{1, 2, 3}
	w := voplay.Vec3{4, 5, 6}
	cross := v.Cross(w)
	assert(cross.X == -3 && cross.Y == 6 && cross.Z == -3, "Vec3.Cross")

	// Quat
	q := voplay.QuatIdentity()
	assert(q.W == 1.0 && q.X == 0 && q.Y == 0 && q.Z == 0, "QuatIdentity")
	q2 := q.Mul(q)
	assert(q2.W == 1.0, "Quat.Mul identity")

	// Rect
	r := voplay.Rect{10, 20, 30, 40}
	assert(r.Contains(25, 35), "Rect.Contains inside")
	assert(!r.Contains(5, 5), "Rect.Contains outside")

	fmt.Println("  math types: ok")
}

func testColor() {
	c := voplay.Hex(0xFF8000)
	assert(c.R == 1.0 && c.A == 1.0, "Hex color")
	assert(c.G > 0.49 && c.G < 0.51, "Hex green channel")
	assert(c.B == 0.0, "Hex blue channel")

	assert(voplay.White.R == 1.0 && voplay.White.G == 1.0 && voplay.White.B == 1.0, "White")
	assert(voplay.Transparent.A == 0.0, "Transparent")

	fmt.Println("  color: ok")
}

func testColliders() {
	box := voplay.Box(10, 20)
	_ = box
	circle := voplay.Circle(5)
	_ = circle
	sphere := voplay.Sphere(3)
	_ = sphere
	fmt.Println("  colliders: ok")
}

func testSceneBasics() {
	// Scene2D spawn + destroy
	s := voplay.Scene2D{}
	e := s.Spawn(voplay.Entity2D{
		X: 10, Y: 20,
		W: 32, H: 32,
		Tag: "player",
	})
	assert(e.Active, "spawned entity is active")
	assert(e.Visible, "spawned entity is visible")
	assert(e.ScaleX == 1, "spawned entity ScaleX default")
	assert(e.ScaleY == 1, "spawned entity ScaleY default")
	assert(e.Tag == "player", "entity tag")

	s.Destroy(e)
	assert(!e.Active, "destroyed entity is inactive")

	// Scene3D spawn
	s3 := voplay.Scene3D{}
	n := s3.Spawn(voplay.Node3D{
		Position: voplay.Vec3{1, 2, 3},
		Tag:      "cube",
	})
	assert(n.Visible, "spawned node is visible")
	assert(n.Scale.X == 1 && n.Scale.Y == 1 && n.Scale.Z == 1, "node default scale")
	assert(n.Rotation.W == 1, "node default rotation is identity")

	fmt.Println("  scenes: ok")
}

func assert(cond bool, msg string) {
	if !cond {
		panic("assertion failed: " + msg)
	}
}
