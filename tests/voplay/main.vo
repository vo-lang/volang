func testMathTypes() {
	// Vec2
	a := voplay.Vec2{3, 4}
	assert(a.Length() == 5.0, "Vec2.Length")
	b := voplay.Vec2{1, 0}
	c := a.Add(b)
	assert(c.X == 4 && c.Y == 4, "Vec2.Add")

	n := a.Normalize()
	assert(n.X == 0.6 && n.Y == 0.8, "Vec2.Normalize")

	// Vec3
	v := voplay.Vec3{1, 2, 3}
	w := voplay.Vec3{4, 5, 6}
	cross := v.Cross(w)
	assert(cross.X == -3 && cross.Y == 6 && cross.Z == -3, "Vec3.Cross")

	// Quat
	q := voplay.QuatIdentity()
	assert(q.W == 1.0 && q.X == 0 && q.Y == 0 && q.Z == 0, "QuatIdentity")
	q2 := q.Mul(q)
	assert(q2.W == 1.0, "Quat.Mul identity")

	// Rect
	r := voplay.Rect{10, 20, 30, 40}
	assert(r.Contains(25, 35), "Rect.Contains inside")
	assert(!r.Contains(5, 5), "Rect.Contains outside")

	fmt.Println("  math types: ok")
}

func testColor() {
	c := voplay.Hex(0xFF8000)
	assert(c.R == 1.0 && c.A == 1.0, "Hex color")
	assert(c.G > 0.49 && c.G < 0.51, "Hex green channel")
	assert(c.B == 0.0, "Hex blue channel")

	assert(voplay.White.R == 1.0 && voplay.White.G == 1.0 && voplay.White.B == 1.0, "White")
	assert(voplay.Transparent.A == 0.0, "Transparent")

	fmt.Println("  color: ok")
}

func testColliders() {
	box := voplay.Box(10, 20)
	_ = box
	circle := voplay.Circle(5)
	_ = circle
	sphere := voplay.Sphere(3)
	_ = sphere
	fmt.Println("  colliders: ok")
}

func testSceneBasics() {
	// Scene2D spawn + destroy
	s := voplay.NewScene2D()
	e := s.Spawn(voplay.Entity2D{
		X: 10, Y: 20,
		W: 32, H: 32,
		Tag: "player",
	})
	assert(e.Active, "spawned entity is active")
	assert(e.Visible, "spawned entity is visible")
	assert(e.ScaleX == 1, "spawned entity ScaleX default")
	assert(e.ScaleY == 1, "spawned entity ScaleY default")
	assert(e.Tag == "player", "entity tag")

	s.Destroy(e)
	assert(!e.Active, "destroyed entity is inactive")

	// Scene3D spawn
	s3 := voplay.Scene3D{}
	n := s3.Spawn(voplay.Node3D{
		Position: voplay.Vec3{1, 2, 3},
		Tag:      "cube",
	})
	assert(n.Visible, "spawned node is visible")
	assert(n.Scale.X == 1 && n.Scale.Y == 1 && n.Scale.Z == 1, "node default scale")
	assert(n.Rotation.W == 1, "node default rotation is identity")

	fmt.Println("  scenes: ok")
}

func testSprite() {
	// NewSprite defaults
	spr := voplay.NewSprite(1, 64, 32)
	assert(spr.Texture == 1, "sprite texture")
	assert(spr.SrcW == 64, "sprite SrcW")
	assert(spr.SrcH == 32, "sprite SrcH")
	assert(spr.SrcX == 0 && spr.SrcY == 0, "sprite SrcX/SrcY default")
	assert(!spr.FlipX && !spr.FlipY, "sprite flip defaults")
	assert(spr.Tint.R == 1.0 && spr.Tint.A == 1.0, "sprite tint default is White")
	assert(spr.Rotation == 0, "sprite rotation default")

	// SpriteSheet frame calculation
	ss := voplay.NewSpriteSheet(1, 32, 32, 4)
	x, y, w, h := ss.Frame(0)
	assert(x == 0 && y == 0 && w == 32 && h == 32, "sheet frame 0")
	x, y, w, h = ss.Frame(3)
	assert(x == 96 && y == 0 && w == 32 && h == 32, "sheet frame 3")
	x, y, w, h = ss.Frame(4)
	assert(x == 0 && y == 32 && w == 32 && h == 32, "sheet frame 4 (row 1)")
	x, y, w, h = ss.Frame(7)
	assert(x == 96 && y == 32 && w == 32 && h == 32, "sheet frame 7")

	fmt.Println("  sprites: ok")
}

func testAnimation() {
	ss := voplay.NewSpriteSheet(1, 16, 16, 4)
	anim := &voplay.Animation{
		Sheet:  ss,
		Frames: []int{0, 1, 2, 3},
		FPS:    10,
		Loop:   true,
	}

	// Start at frame 0
	x, _, _, _ := anim.CurrentFrame()
	assert(x == 0, "anim starts at frame 0")

	// Advance past one frame (0.1s at 10fps)
	anim.Update(0.11)
	x, _, _, _ = anim.CurrentFrame()
	assert(x == 16, "anim advances to frame 1")

	// Advance through remaining frames + wrap
	anim.Update(0.3) // 3 more frames
	x, _, _, _ = anim.CurrentFrame()
	assert(x == 0, "anim loops back to frame 0")
	assert(!anim.Done(), "looping anim is never done")

	// Non-looping animation
	anim2 := &voplay.Animation{
		Sheet:  ss,
		Frames: []int{0, 1},
		FPS:    10,
		Loop:   false,
	}
	anim2.Update(0.5) // way past end
	assert(anim2.Done(), "non-loop anim is done")
	_, y, _, _ := anim2.CurrentFrame()
	_ = y

	// Reset
	anim2.Reset()
	assert(!anim2.Done(), "reset clears done")
	x, _, _, _ = anim2.CurrentFrame()
	assert(x == 0, "reset goes to frame 0")

	fmt.Println("  animation: ok")
}

func testCamera2D() {
	c := voplay.Camera2D{Zoom: 1.0}

	// Follow
	c.Follow(100, 200)
	assert(c.X == 100 && c.Y == 200, "Camera2D.Follow")

	// LerpFollow
	c.LerpFollow(200, 400, 0.5)
	assert(c.X == 150 && c.Y == 300, "Camera2D.LerpFollow")

	// ScreenToWorld — camera at origin, zoom=1
	c2 := voplay.Camera2D{Zoom: 1.0}
	wx, wy := c2.ScreenToWorld(400, 300, 800, 600)
	assert(wx == 0 && wy == 0, "ScreenToWorld center")

	wx, wy = c2.ScreenToWorld(0, 0, 800, 600)
	assert(wx == -400 && wy == -300, "ScreenToWorld top-left")

	// WorldToScreen
	sx, sy := c2.WorldToScreen(0, 0, 800, 600)
	assert(sx == 400 && sy == 300, "WorldToScreen origin")

	// ViewRect
	vr := c2.ViewRect(800, 600)
	assert(vr.W == 800 && vr.H == 600, "ViewRect size at zoom 1")
	assert(vr.X == -400 && vr.Y == -300, "ViewRect position at origin")

	// ViewRect with zoom
	c3 := voplay.Camera2D{Zoom: 2.0}
	vr2 := c3.ViewRect(800, 600)
	assert(vr2.W == 400 && vr2.H == 300, "ViewRect size at zoom 2")

	fmt.Println("  camera2d: ok")
}

func testSceneQueries() {
	s := voplay.NewScene2D()

	a := s.Spawn(voplay.Entity2D{X: 10, Y: 10, W: 32, H: 32, Tag: "player"})
	b := s.Spawn(voplay.Entity2D{X: 50, Y: 50, W: 16, H: 16, Tag: "enemy"})
	c := s.Spawn(voplay.Entity2D{X: 90, Y: 90, W: 16, H: 16, Tag: "enemy"})
	_ = c

	// FindByTag
	found := s.FindByTag("player")
	assert(found == a, "FindByTag player")
	found = s.FindByTag("enemy")
	assert(found == b, "FindByTag enemy returns first")
	found = s.FindByTag("nonexistent")
	assert(found == nil, "FindByTag nonexistent")

	// EntityCount
	assert(s.EntityCount() == 3, "EntityCount")

	// ForEach
	count := 0
	s.ForEach(func(e *voplay.Entity2D) {
		count++
	})
	assert(count == 3, "ForEach count")

	// Entities
	all := s.Entities()
	assert(len(all) == 3, "Entities len")

	// After destroy
	s.Destroy(b)
	assert(s.EntityCount() == 2, "EntityCount after destroy")
	found = s.FindByTag("enemy")
	assert(found == c, "FindByTag returns next enemy after destroy")

	fmt.Println("  scene queries: ok")
}

func testTilemap() {
	ts := &voplay.TileSet{Texture: 1, TileW: 32, TileH: 32, Columns: 4}
	tm := voplay.NewTilemap(ts, 10, 10)

	// Default: all tiles are -1 (empty)
	assert(tm.GetTile(0, 0, 0) == -1, "tilemap default empty")
	assert(tm.GetTile(0, 5, 5) == -1, "tilemap default empty mid")

	// SetTile / GetTile
	tm.SetTile(0, 3, 4, 7)
	assert(tm.GetTile(0, 3, 4) == 7, "SetTile/GetTile")

	// Out-of-bounds returns -1
	assert(tm.GetTile(0, -1, 0) == -1, "GetTile OOB neg")
	assert(tm.GetTile(0, 100, 0) == -1, "GetTile OOB large")
	assert(tm.GetTile(5, 0, 0) == -1, "GetTile bad layer")

	// Fill
	tm.Fill(0, 2)
	assert(tm.GetTile(0, 0, 0) == 2, "Fill")
	assert(tm.GetTile(0, 9, 9) == 2, "Fill corner")

	// FillRect
	tm.FillRect(0, 2, 2, 3, 3, 5)
	assert(tm.GetTile(0, 2, 2) == 5, "FillRect start")
	assert(tm.GetTile(0, 4, 4) == 5, "FillRect end")
	assert(tm.GetTile(0, 1, 1) == 2, "FillRect outside")

	// AddLayer
	layer1 := tm.AddLayer()
	assert(layer1 == 1, "AddLayer returns index")
	assert(tm.GetTile(1, 0, 0) == -1, "new layer is empty")

	// WorldToTile / TileToWorld
	col, row := tm.WorldToTile(65, 97)
	assert(col == 2 && row == 3, "WorldToTile")
	wx, wy := tm.TileToWorld(2, 3)
	assert(wx == 64 && wy == 96, "TileToWorld")

	// PixelWidth / PixelHeight
	assert(tm.PixelWidth() == 320, "PixelWidth")
	assert(tm.PixelHeight() == 320, "PixelHeight")

	// DrawTilemap produces output
	var d voplay.DrawCtx
	d.DrawTilemap(tm, 0, 0, 0, 320, 320)
	assert(len(d.Bytes()) > 0, "DrawTilemap produces output")

	fmt.Println("  tilemap: ok")
}

func testDrawScene2D() {
	s := voplay.NewScene2D()

	spr := voplay.NewSprite(1, 32, 32)

	// Spawn entities with different ZOrders
	s.Spawn(voplay.Entity2D{X: 100, Y: 100, W: 32, H: 32, Sprite: spr, ZOrder: 2})
	s.Spawn(voplay.Entity2D{X: 200, Y: 200, W: 32, H: 32, Sprite: spr, ZOrder: 0})
	s.Spawn(voplay.Entity2D{X: 300, Y: 300, W: 32, H: 32, ZOrder: 1}) // no sprite — should be skipped
	s.Spawn(voplay.Entity2D{X: 400, Y: 400, W: 32, H: 32, Sprite: spr, ZOrder: 1})

	// DrawScene2D should not panic
	var d voplay.DrawCtx
	d.DrawScene2D(s)

	// Verify it produced bytes (camera + sprite commands)
	assert(len(d.Bytes()) > 0, "DrawScene2D produces output")

	fmt.Println("  draw scene2d: ok")
}

func testDrawOutlines() {
	var d voplay.DrawCtx

	// DrawRectOutline emits 4 lines
	d.DrawRectOutline(10, 10, 100, 50, 2, voplay.White)
	assert(len(d.Bytes()) > 0, "DrawRectOutline produces output")

	// DrawCircleOutline
	var d2 voplay.DrawCtx
	d2.DrawCircleOutline(100, 100, 50, 1, 16, voplay.Red)
	assert(len(d2.Bytes()) > 0, "DrawCircleOutline produces output")

	// MeasureText
	w, h := voplay.MeasureText("Hello", 16)
	assert(w == 80, "MeasureText width 5 chars * 16px")
	assert(h == 16, "MeasureText height")

	w2, _ := voplay.MeasureText("", 24)
	assert(w2 == 0, "MeasureText empty string")

	fmt.Println("  outlines + measure: ok")
}

func testPhysics() {
	// Create a scene with gravity
	s := voplay.NewScene2D()
	s.Gravity = voplay.Vec2{0, 98.0}

	// Spawn a dynamic body at y=0 with a box collider
	ball := s.Spawn(voplay.Entity2D{
		X: 100, Y: 0, W: 20, H: 20,
		Physics: &voplay.Physics2D{
			Type:     voplay.Dynamic,
			Collider: voplay.Box(10, 10),
			Density:  1.0,
			Friction: 0.3,
		},
	})
	assert(ball.Physics != nil, "ball has physics")

	// Spawn a static ground
	ground := s.Spawn(voplay.Entity2D{
		X: 100, Y: 500, W: 400, H: 20,
		Physics: &voplay.Physics2D{
			Type:     voplay.Static,
			Collider: voplay.Box(200, 10),
		},
	})
	_ = ground

	// Step physics several times (simulate 0.5 seconds)
	for i := 0; i < 30; i++ {
		s.StepAndSyncPhysics(1.0 / 60.0)
	}

	// Ball should have fallen (Y increased due to gravity)
	assert(ball.Y > 0, "ball fell due to gravity")

	// Ball should have velocity
	v := ball.Velocity()
	assert(v.Y > 0, "ball has downward velocity")

	// Destroy the ball
	s.Destroy(ball)
	assert(s.EntityCount() == 1, "entity removed after destroy")

	fmt.Println("  physics: ok")
}

func testEntityHelpers() {
	s := voplay.NewScene2D()
	a := s.Spawn(voplay.Entity2D{X: 10, Y: 20, W: 30, H: 40})
	b := s.Spawn(voplay.Entity2D{X: 15, Y: 25, W: 30, H: 40})

	// Center
	c := a.Center()
	assert(c.X == 10 && c.Y == 20, "Entity2D.Center")

	// Bounds
	r := a.Bounds()
	assert(r.X == -5 && r.Y == 0 && r.W == 30 && r.H == 40, "Entity2D.Bounds")

	// Overlaps (nearby entities with large size should overlap)
	assert(a.Overlaps(b), "Entity2D.Overlaps (overlapping)")

	// DistanceTo
	dist := a.DistanceTo(b)
	assert(dist > 0, "Entity2D.DistanceTo > 0")

	// Non-overlapping
	far := s.Spawn(voplay.Entity2D{X: 1000, Y: 1000, W: 10, H: 10})
	assert(!a.Overlaps(far), "Entity2D.Overlaps (non-overlapping)")

	// SetPosition (non-physics entity, direct)
	a.SetPosition(100, 200)
	assert(a.Center().X == 100 && a.Center().Y == 200, "Entity2D.SetPosition")

	// FindInRadius
	nearby := s.FindInRadius(10, 20, 50)
	assert(len(nearby) >= 1, "FindInRadius finds nearby entity")
	farAway := s.FindInRadius(-9999, -9999, 1)
	assert(len(farAway) == 0, "FindInRadius returns empty for distant point")

	fmt.Println("  entity helpers: ok")
}

func testColorHelpers() {
	c := voplay.Red

	// WithAlpha
	c2 := c.WithAlpha(0.5)
	assert(c2.R == 1 && c2.G == 0 && c2.B == 0 && c2.A == 0.5, "Color.WithAlpha")

	// Lerp
	c3 := voplay.Black.Lerp(voplay.White, 0.5)
	assert(c3.R == 0.5 && c3.G == 0.5 && c3.B == 0.5, "Color.Lerp midpoint")

	// Lerp at 0 and 1
	c4 := voplay.Red.Lerp(voplay.Blue, 0)
	assert(c4.R == 1 && c4.B == 0, "Color.Lerp at 0")
	c5 := voplay.Red.Lerp(voplay.Blue, 1)
	assert(c5.R == 0 && c5.B == 1, "Color.Lerp at 1")

	fmt.Println("  color helpers: ok")
}

func testSceneClear() {
	s := voplay.NewScene2D()
	s.Spawn(voplay.Entity2D{Tag: "a", W: 10, H: 10})
	s.Spawn(voplay.Entity2D{Tag: "b", W: 10, H: 10})
	s.Spawn(voplay.Entity2D{Tag: "a", W: 10, H: 10})

	// FindAllByTag
	all := s.FindAllByTag("a")
	assert(len(all) == 2, "FindAllByTag returns 2")
	none := s.FindAllByTag("x")
	assert(len(none) == 0, "FindAllByTag returns 0 for missing")

	// Clear
	assert(s.EntityCount() == 3, "3 entities before clear")
	s.Clear()
	assert(s.EntityCount() == 0, "0 entities after clear")

	// Spawn after clear should still work
	s.Spawn(voplay.Entity2D{Tag: "c", W: 5, H: 5})
	assert(s.EntityCount() == 1, "1 entity after re-spawn")

	fmt.Println("  scene clear: ok")
}

func testContacts() {
	// Contacts on a scene without physics should return nil
	s := voplay.NewScene2D()
	s.Spawn(voplay.Entity2D{W: 10, H: 10})
	c := s.Contacts()
	assert(c == nil, "Contacts nil without physics")

	fmt.Println("  contacts: ok")
}

func testAudio() {
	// LoadAudio with nonexistent file should return an error
	_, err := voplay.LoadAudio("/nonexistent/audio.wav")
	assert(err != nil, "LoadAudio nonexistent file returns error")

	// Volume control calls should not crash
	voplay.SetSFXVolume(0.5)
	voplay.SetMusicVolume(0.8)

	// Stop/pause/resume with no music playing should not crash
	voplay.StopMusic()
	voplay.PauseMusic()
	voplay.ResumeMusic()

	// Free on invalid clip should not crash
	voplay.AudioClip(0).Free()

	fmt.Println("  audio: ok")
}

func testDrawEncoding() {
	d := voplay.NewDrawCtx()

	// SetLayer encoding: opcode 0x05, then 2 bytes (u16 little-endian)
	d.SetLayer(42)
	buf := d.Bytes()
	assert(buf[0] == 0x05, "SetLayer opcode is 0x05")
	assert(buf[1] == 42, "SetLayer z low byte")
	assert(buf[2] == 0, "SetLayer z high byte")

	// Clear encoding: opcode 0x01, then 4 x f64 (32 bytes)
	d2 := voplay.NewDrawCtx()
	d2.Clear(1, 0, 0, 1)
	buf2 := d2.Bytes()
	assert(buf2[0] == 0x01, "Clear opcode is 0x01")
	assert(len(buf2) == 1+4*8, "Clear is 1 opcode + 4 f64")

	// DrawRect encoding: opcode 0x11, then 8 x f64 (64 bytes)
	d3 := voplay.NewDrawCtx()
	d3.DrawRect(10, 20, 100, 50, voplay.Red)
	buf3 := d3.Bytes()
	assert(buf3[0] == 0x11, "DrawRect opcode is 0x11")
	assert(len(buf3) == 1+8*8, "DrawRect is 1 opcode + 8 f64")

	// SetLayer with a larger value (layer 300 = 0x012C)
	d4 := voplay.NewDrawCtx()
	d4.SetLayer(300)
	buf4 := d4.Bytes()
	assert(buf4[0] == 0x05, "SetLayer opcode")
	assert(buf4[1] == 0x2C, "SetLayer 300 low byte")
	assert(buf4[2] == 0x01, "SetLayer 300 high byte")

	// Multiple SetLayer + draw interleaving produces correct stream
	d5 := voplay.NewDrawCtx()
	d5.SetLayer(0)
	d5.DrawRect(0, 0, 10, 10, voplay.Red)
	d5.SetLayer(5)
	d5.DrawRect(0, 0, 20, 20, voplay.Blue)
	buf5 := d5.Bytes()
	// Structure: SetLayer(0) + DrawRect + SetLayer(5) + DrawRect
	assert(buf5[0] == 0x05, "first opcode is SetLayer")
	setLayerSize := 1 + 2 // opcode + u16
	drawRectSize := 1 + 8*8 // opcode + 8 f64
	secondSetLayerStart := setLayerSize + drawRectSize
	assert(buf5[secondSetLayerStart] == 0x05, "second SetLayer opcode at correct offset")
	assert(buf5[secondSetLayerStart+1] == 5, "second SetLayer z=5")

	fmt.Println("  draw encoding: ok")
}

func testScene3D() {
	s := voplay.NewScene3D()

	// Default camera
	assert(s.Camera.Fov == 60, "Scene3D default camera fov")
	assert(s.Camera.Near == 0.1, "Scene3D default camera near")
	assert(s.Camera.Far == 1000, "Scene3D default camera far")

	// Spawn
	n1 := s.Spawn(voplay.Node3D{Tag: "cube", Model: 1})
	assert(n1.Visible, "Node3D visible after spawn")
	assert(n1.Scale.X == 1 && n1.Scale.Y == 1 && n1.Scale.Z == 1, "Node3D default scale")
	assert(n1.Rotation.W == 1, "Node3D default rotation is identity")
	assert(s.NodeCount() == 1, "Scene3D has 1 node")

	n2 := s.Spawn(voplay.Node3D{Tag: "sphere", Model: 2})
	assert(s.NodeCount() == 2, "Scene3D has 2 nodes")

	// FindByTag
	cubes := s.FindByTag("cube")
	assert(len(cubes) == 1, "FindByTag cube")
	assert(cubes[0] == n1, "FindByTag returns correct node")
	none := s.FindByTag("missing")
	assert(len(none) == 0, "FindByTag returns empty for missing")

	// ForEach
	count := 0
	s.ForEach(func(n *voplay.Node3D) { count++ })
	assert(count == 2, "ForEach visits all nodes")

	// AddLight / ClearLights
	assert(len(s.Lights) == 0, "No lights initially")
	s.AddLight(voplay.Light{
		Type:      voplay.DirectionalLight,
		Direction: voplay.Vec3{0, -1, 0},
		Color:     voplay.White,
		Intensity: 1,
	})
	assert(len(s.Lights) == 1, "1 light after AddLight")
	s.ClearLights()
	assert(len(s.Lights) == 0, "0 lights after ClearLights")

	// Destroy
	s.Destroy(n1)
	assert(s.NodeCount() == 1, "1 node after destroy")

	// Clear
	s.Clear()
	assert(s.NodeCount() == 0, "0 nodes after clear")

	// Spawn after clear
	s.Spawn(voplay.Node3D{Tag: "new"})
	assert(s.NodeCount() == 1, "1 node after re-spawn")

	_ = n2
	fmt.Println("  scene3d: ok")
}

func testMath3D() {
	// Vec3.Negate
	v := voplay.Vec3{1, 2, 3}
	n := v.Negate()
	assert(n.X == -1 && n.Y == -2 && n.Z == -3, "Vec3.Negate")

	// QuatIdentity
	q := voplay.QuatIdentity()
	assert(q.W == 1 && q.X == 0 && q.Y == 0 && q.Z == 0, "QuatIdentity")

	// Quat.Inverse
	qi := q.Inverse()
	assert(qi.W == 1 && qi.X == 0, "QuatIdentity.Inverse")

	// QuatFromAxisAngle + RotateVec3
	// 90 degrees around Y axis should rotate (1,0,0) to approximately (0,0,-1)
	rot := voplay.QuatFromAxisAngle(voplay.Vec3{0, 1, 0}, 1.5707963267948966) // PI/2
	rotated := rot.RotateVec3(voplay.Vec3{1, 0, 0})
	assert(rotated.X < 0.001 && rotated.X > -0.001, "RotateVec3 x near 0")
	assert(rotated.Z < -0.999, "RotateVec3 z near -1")

	// QuatFromEuler + ToAxisAngle round-trip
	qe := voplay.QuatFromEuler(0.5, 0.3, 0.1)
	axis, angle := qe.ToAxisAngle()
	assert(angle > 0, "ToAxisAngle angle > 0")
	assert(axis.Length() > 0.99, "ToAxisAngle axis is unit")

	// Slerp at t=0 and t=1
	qa := voplay.QuatIdentity()
	qb := voplay.QuatFromAxisAngle(voplay.Vec3{0, 0, 1}, 1.0)
	s0 := qa.Slerp(qb, 0)
	assert(s0.W > 0.999, "Slerp t=0 returns start")
	s1 := qa.Slerp(qb, 1)
	assert(s1.W-qb.W < 0.001 && s1.W-qb.W > -0.001, "Slerp t=1 returns end")

	fmt.Println("  math3d: ok")
}

func testDraw3DEncoding() {
	d := voplay.NewDrawCtx()

	// SetCamera3D encoding
	cam := voplay.Camera3D{
		Position: voplay.Vec3{0, 5, 10},
		Target:   voplay.Vec3{0, 0, 0},
		Up:       voplay.Vec3{0, 1, 0},
		Fov:      60,
		Near:     0.1,
		Far:      1000,
	}
	d.SetCamera3D(&cam)
	assert(len(d.Bytes()) > 0, "SetCamera3D encodes bytes")

	// SetLights3D encoding
	lights := []voplay.Light{
		{
			Type:      voplay.DirectionalLight,
			Direction: voplay.Vec3{0, -1, 0},
			Color:     voplay.White,
			Intensity: 1,
		},
	}
	d.SetLights3D(voplay.Color{R: 0.2, G: 0.2, B: 0.2, A: 1}, lights)

	// DrawModel encoding
	d.DrawModel(1, voplay.Vec3{0, 0, 0}, voplay.QuatIdentity(), voplay.Vec3{1, 1, 1})

	buf := d.Bytes()
	// First byte should be opSetCamera3D (0x03)
	assert(buf[0] == 0x03, "first opcode is SetCamera3D")
	assert(len(buf) > 100, "3D draw stream has substantial data")

	// DrawScene3D should work without panic
	s := voplay.NewScene3D()
	s.Spawn(voplay.Node3D{Model: 1, Position: voplay.Vec3{0, 0, 0}})
	s.AddLight(voplay.Light{
		Type:      voplay.DirectionalLight,
		Direction: voplay.Vec3{0, -1, 0},
		Color:     voplay.White,
		Intensity: 1,
	})
	d2 := voplay.NewDrawCtx()
	d2.DrawScene3D(s)
	assert(len(d2.Bytes()) > 0, "DrawScene3D encodes data")

	fmt.Println("  draw3d encoding: ok")
}

func testCamera3DMethods() {
	cam := voplay.Camera3D{
		Position: voplay.Vec3{0, 5, 10},
		Target:   voplay.Vec3{0, 0, 0},
		Up:       voplay.Vec3{0, 1, 0},
		Fov:      60,
		Near:     0.1,
		Far:      1000,
	}

	// LookAt
	cam.LookAt(voplay.Vec3{1, 2, 3}, voplay.Vec3{4, 5, 6})
	assert(cam.Position.X == 1 && cam.Position.Y == 2 && cam.Position.Z == 3, "Camera3D.LookAt position")
	assert(cam.Target.X == 4 && cam.Target.Y == 5 && cam.Target.Z == 6, "Camera3D.LookAt target")

	// Orbit
	cam.Up = voplay.Vec3{0, 1, 0}
	cam.Orbit(voplay.Vec3{0, 0, 0}, 10, 0, 0)
	// At yaw=0, pitch=0: position should be (10, 0, 0) approximately
	assert(cam.Target.X == 0 && cam.Target.Y == 0 && cam.Target.Z == 0, "Camera3D.Orbit target stays at center")
	// Position should be at distance 10 from origin
	dist := cam.Position.Length()
	assert(dist > 9.9 && dist < 10.1, "Camera3D.Orbit distance preserved")

	// ScreenToRay
	cam.LookAt(voplay.Vec3{0, 0, 5}, voplay.Vec3{0, 0, 0})
	cam.Up = voplay.Vec3{0, 1, 0}
	cam.Fov = 60
	origin, dir := cam.ScreenToRay(400, 300, 800, 600)
	assert(origin.X == 0 && origin.Y == 0 && origin.Z == 5, "ScreenToRay origin is camera position")
	// Center of screen should give a ray roughly pointing forward (negative Z)
	assert(dir.Z < 0, "ScreenToRay center ray points forward")

	fmt.Println("  camera3d methods: ok")
}

func testScene3DAmbient() {
	s := voplay.NewScene3D()
	// Default ambient should be (0.1, 0.1, 0.1, 1)
	assert(s.Ambient.R == 0.1, "Scene3D default ambient R")
	assert(s.Ambient.A == 1, "Scene3D default ambient A")

	// Set custom ambient
	s.Ambient = voplay.Color{0.3, 0.3, 0.5, 1}
	assert(s.Ambient.B == 0.5, "Scene3D custom ambient B")

	// DrawScene3D should use the scene's ambient (not hardcoded)
	s.Spawn(voplay.Node3D{Model: 1, Position: voplay.Vec3{0, 0, 0}})
	s.AddLight(voplay.Light{
		Type:      voplay.DirectionalLight,
		Direction: voplay.Vec3{0, -1, 0},
		Color:     voplay.White,
		Intensity: 1,
	})
	d := voplay.NewDrawCtx()
	d.DrawScene3D(s)
	buf := d.Bytes()
	assert(len(buf) > 0, "DrawScene3D with custom ambient encodes data")

	fmt.Println("  scene3d ambient: ok")
}

func testScene3DPhysicsConfig() {
	s := voplay.NewScene3D()

	// Spawn nodes WITHOUT physics (no extern calls needed)
	node := s.Spawn(voplay.Node3D{
		Position: voplay.Vec3{0, 10, 0},
		Model:    1,
	})
	assert(node.Position.Y == 10, "Node3D spawned at correct position")
	assert(s.NodeCount() == 1, "Scene3D has 1 node after spawn")

	ground := s.Spawn(voplay.Node3D{
		Position: voplay.Vec3{0, 0, 0},
		Model:    2,
	})
	assert(s.NodeCount() == 2, "Scene3D has 2 nodes")

	ball := s.Spawn(voplay.Node3D{
		Position: voplay.Vec3{5, 5, 0},
	})
	assert(s.NodeCount() == 3, "Scene3D has 3 nodes")

	// SetPosition on non-physics node updates directly
	node.SetPosition(voplay.Vec3{0, 20, 0})
	assert(node.Position.Y == 20, "SetPosition updates Position immediately")

	// Velocity is zero on non-physics nodes
	vel := ball.Velocity()
	assert(vel.X == 0 && vel.Y == 0 && vel.Z == 0, "Velocity is zero on non-physics node")

	// Force methods should not panic on non-physics nodes
	node.ApplyForce(voplay.Vec3{0, 100, 0})
	node.ApplyImpulse(voplay.Vec3{10, 0, 0})
	node.SetVelocity(voplay.Vec3{1, 2, 3})

	// Destroy
	s.Destroy(ground)
	assert(s.NodeCount() == 2, "Scene3D has 2 nodes after destroy")

	// Clear
	s.Clear()
	assert(s.NodeCount() == 0, "Scene3D empty after clear")

	// Test 3D collider constructors (pure Vo, no externs)
	box := voplay.Box3D(1, 2, 3)
	_ = box
	sphere := voplay.Sphere(0.5)
	_ = sphere
	capsule := voplay.Capsule(1.0, 0.3)
	_ = capsule

	// Test Physics3D struct construction (no Spawn, so no extern)
	p := &voplay.Physics3D{
		Type:        voplay.Dynamic,
		Collider:    voplay.Box3D(1, 1, 1),
		Density:     2.0,
		Friction:    0.5,
		Restitution: 0.3,
	}
	assert(p.Density == 2.0, "Physics3D density")
	assert(p.Friction == 0.5, "Physics3D friction")

	fmt.Println("  scene3d physics config: ok")
}

func testPointerDelta() {
	// PointerDelta should return (0, 0) initially
	inp := voplay.NewInputState()
	dx, dy := inp.PointerDelta()
	assert(dx == 0 && dy == 0, "PointerDelta initial zero")

	fmt.Println("  pointer delta: ok")
}

func test25DDrawScene() {
	s := voplay.NewScene2D()
	s.ViewAngle = 60

	// Spawn an entity with a Model (2.5D)
	s.Spawn(voplay.Entity2D{
		X: 100, Y: 200, W: 32, H: 32,
		Model:  1,
		ScaleX: 1, ScaleY: 1,
	})

	// Spawn a normal sprite entity
	spr := &voplay.Sprite{Texture: 1, SrcW: 32, SrcH: 32}
	s.Spawn(voplay.Entity2D{
		X: 50, Y: 50, W: 32, H: 32,
		Sprite: spr,
		ScaleX: 1, ScaleY: 1,
	})

	d := voplay.NewDrawCtx()
	d.DrawScene2D(s)
	buf := d.Bytes()
	assert(len(buf) > 0, "DrawScene2D with 2.5D entities encodes data")

	fmt.Println("  2.5d draw scene: ok")
}

