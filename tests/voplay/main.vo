func testRayCastHitTypes() {
	// Test RayCastHit2D struct construction
	hit2d := voplay.RayCastHit2D{
		Point:    voplay.Vec2{10, 20},
		Normal:   voplay.Vec2{0, -1},
		Distance: 5.5,
	}
	assert(hit2d.Point.X == 10, "RayCastHit2D point")
	assert(hit2d.Normal.Y == -1, "RayCastHit2D normal")
	assert(hit2d.Distance == 5.5, "RayCastHit2D distance")

	// Test RayCastHit3D struct construction
	hit3d := voplay.RayCastHit3D{
		Point:    voplay.Vec3{1, 2, 3},
		Normal:   voplay.Vec3{0, 1, 0},
		Distance: 10.0,
	}
	assert(hit3d.Point.Z == 3, "RayCastHit3D point")
	assert(hit3d.Normal.Y == 1, "RayCastHit3D normal")
	assert(hit3d.Distance == 10.0, "RayCastHit3D distance")

	fmt.Println("  raycast hit types: ok")
}

func testDrawBillboard() {
	d := voplay.NewDrawCtx()
	spr := &voplay.Sprite{Texture: 1, SrcW: 32, SrcH: 32}

	// Set up a 3D camera first
	cam := voplay.Camera3D{
		Position: voplay.Vec3{0, 5, 10},
		Target:   voplay.Vec3{0, 0, 0},
		Up:       voplay.Vec3{0, 1, 0},
		Fov:      60, Near: 0.1, Far: 1000,
	}
	d.SetCamera3D(&cam)

	// DrawBillboard should encode without panic
	d.DrawBillboard(spr, voplay.Vec3{0, 2, 0}, 1.0, 0.5)
	buf := d.Bytes()
	assert(len(buf) > 0, "DrawBillboard encodes data")

	fmt.Println("  draw billboard: ok")
}

func testScene3DRayCast() {
	// RayCast on empty scene (no physics) should return nil
	s := voplay.NewScene3D()
	hit := s.RayCast(voplay.Vec3{0, 10, 0}, voplay.Vec3{0, -1, 0}, 100)
	assert(hit == nil, "RayCast nil on empty scene")

	fmt.Println("  scene3d raycast: ok")
}

func testScene2DRayCastQueryRect() {
	// RayCast and QueryRect on scene without physics should return nil
	s := voplay.NewScene2D()
	hit := s.RayCast(voplay.Vec2{0, 0}, voplay.Vec2{1, 0}, 100)
	assert(hit == nil, "RayCast nil on non-physics scene")

	result := s.QueryRect(voplay.Rect{0, 0, 100, 100})
	assert(result == nil, "QueryRect nil on non-physics scene")

	fmt.Println("  scene2d raycast/queryrect: ok")
}

func assert(cond bool, msg string) {
	if !cond {
		panic("assertion failed: " + msg)
	}
}
