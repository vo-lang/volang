func testMathTypes() {
	a := voplay.Vec2{3, 4}
	assert(a.Length() == 5.0, "Vec2.Length")
	b := voplay.Vec2{1, 0}
	c := a.Add(b)
	assert(c.X == 4 && c.Y == 4, "Vec2.Add")

	n := a.Normalize()
	assert(n.X == 0.6 && n.Y == 0.8, "Vec2.Normalize")

	v := voplay.Vec3{1, 2, 3}
	w := voplay.Vec3{4, 5, 6}
	cross := v.Cross(w)
	assert(cross.X == -3 && cross.Y == 6 && cross.Z == -3, "Vec3.Cross")

	q := voplay.QuatIdentity()
	assert(q.W == 1.0 && q.X == 0 && q.Y == 0 && q.Z == 0, "QuatIdentity")
	q2 := q.Mul(q)
	assert(q2.W == 1.0, "Quat.Mul identity")

	r := voplay.Rect{10, 20, 30, 40}
	assert(r.Contains(25, 35), "Rect.Contains inside")
	assert(!r.Contains(5, 5), "Rect.Contains outside")

	fmt.Println("  math types: ok")
}

func testColor() {
	c := voplay.Hex(0xFF8000)
	assert(c.R == 1.0 && c.A == 1.0, "Hex color")
	assert(c.G > 0.49 && c.G < 0.51, "Hex green channel")
	assert(c.B == 0.0, "Hex blue channel")

	assert(voplay.White.R == 1.0 && voplay.White.G == 1.0 && voplay.White.B == 1.0, "White")
	assert(voplay.Transparent.A == 0.0, "Transparent")

	fmt.Println("  color: ok")
}

func testColliders() {
	box2d := scene2d.Box(10, 20)
	assert(box2d.Kind() == scene2d.ColliderBox, "scene2d.Box kind")
	circle2d := scene2d.Circle(5)
	assert(circle2d.Kind() == scene2d.ColliderCircle, "scene2d.Circle kind")
	sphere3d := scene3d.Sphere(3)
	assert(sphere3d.Kind() == scene3d.ColliderSphere, "scene3d.Sphere kind")

	fmt.Println("  colliders: ok")
}

func testSceneBasics() {
	s := scene2d.New()
	e := s.Spawn(scene2d.EntityDesc{
		Position: voplay.Vec2{10, 20},
		Size:     voplay.Vec2{32, 32},
		Tag:      "player",
	})
	assert(e.Active, "spawned entity is active")
	assert(e.Visible, "spawned entity is visible")
	scale := e.Scale()
	assert(scale.X == 1, "spawned entity ScaleX default")
	assert(scale.Y == 1, "spawned entity ScaleY default")
	assert(e.Tag == "player", "entity tag")
	assert(s.FindByTag("player") == e, "scene2d FindByTag")

	s.Destroy(e)
	assert(!e.Active, "destroyed entity is inactive")

	s3 := scene3d.New()
	n := s3.Spawn(scene3d.Entity{
		Position: voplay.Vec3{1, 2, 3},
		Tag:      "cube",
	})
	assert(n.Visible, "spawned node is visible")
	assert(n.Scale.X == 1 && n.Scale.Y == 1 && n.Scale.Z == 1, "node default scale")
	assert(n.Rotation.W == 1, "node default rotation is identity")
	assert(s3.FindByTag("cube") == n, "scene3d FindByTag")

	fmt.Println("  scenes: ok")
}

func testSprite() {
	spr := scene2d.NewSprite(1, 64, 32)
	assert(spr.Texture == 1, "sprite texture")
	assert(spr.SrcW == 64, "sprite SrcW")
	assert(spr.SrcH == 32, "sprite SrcH")
	assert(spr.SrcX == 0 && spr.SrcY == 0, "sprite SrcX/SrcY default")
	assert(!spr.FlipX && !spr.FlipY, "sprite flip defaults")
	assert(spr.Tint.R == 1.0 && spr.Tint.A == 1.0, "sprite tint default is White")
	assert(spr.Rotation == 0, "sprite rotation default")

	ss := scene2d.NewSpriteSheet(1, 32, 32, 4)
	x, y, w, h := ss.Frame(0)
	assert(x == 0 && y == 0 && w == 32 && h == 32, "sheet frame 0")
	x, y, w, h = ss.Frame(3)
	assert(x == 96 && y == 0 && w == 32 && h == 32, "sheet frame 3")
	x, y, w, h = ss.Frame(4)
	assert(x == 0 && y == 32 && w == 32 && h == 32, "sheet frame 4")
	x, y, w, h = ss.Frame(7)
	assert(x == 96 && y == 32 && w == 32 && h == 32, "sheet frame 7")

	fmt.Println("  sprites: ok")
}

func testAnimation() {
	ss := scene2d.NewSpriteSheet(1, 16, 16, 4)
	anim := &scene2d.Animation{
		Sheet:  ss,
		Frames: []int{0, 1, 2, 3},
		FPS:    10,
		Loop:   true,
	}

	x, _, _, _ := anim.CurrentFrame()
	assert(x == 0, "anim starts at frame 0")

	anim.Update(0.11)
	x, _, _, _ = anim.CurrentFrame()
	assert(x == 16, "anim advances to frame 1")

	anim.Update(0.3)
	x, _, _, _ = anim.CurrentFrame()
	assert(x == 0, "anim loops back to frame 0")
	assert(!anim.Done(), "looping anim is never done")

	anim2 := &scene2d.Animation{
		Sheet:  ss,
		Frames: []int{0, 1},
		FPS:    10,
		Loop:   false,
	}
	anim2.Update(0.5)
	assert(anim2.Done(), "non-loop anim is done")

	anim2.Reset()
	assert(!anim2.Done(), "reset clears done")
	x, _, _, _ = anim2.CurrentFrame()
	assert(x == 0, "reset goes to frame 0")

	fmt.Println("  animation: ok")
}

func testCamera2D() {
	c := scene2d.Camera{Zoom: 1.0}
	c.Follow(100, 200)
	assert(c.X == 100 && c.Y == 200, "Camera2D.Follow")

	c.LerpFollow(200, 400, 0.5)
	assert(c.X == 150 && c.Y == 300, "Camera2D.LerpFollow")

	c2 := scene2d.Camera{Zoom: 1.0}
	wx, wy := c2.ScreenToWorld(400, 300, 800, 600)
	assert(wx == 0 && wy == 0, "ScreenToWorld center")

	wx, wy = c2.ScreenToWorld(0, 0, 800, 600)
	assert(wx == -400 && wy == -300, "ScreenToWorld top-left")

	sx, sy := c2.WorldToScreen(0, 0, 800, 600)
	assert(sx == 400 && sy == 300, "WorldToScreen origin")

	vr := c2.ViewRect(800, 600)
	assert(vr.W == 800 && vr.H == 600, "ViewRect size at zoom 1")
	assert(vr.X == -400 && vr.Y == -300, "ViewRect position at origin")

	c3 := scene2d.Camera{Zoom: 2.0}
	vr2 := c3.ViewRect(800, 600)
	assert(vr2.W == 400 && vr2.H == 300, "ViewRect size at zoom 2")

	fmt.Println("  camera2d: ok")
}

func testSceneQueries() {
	s := scene2d.New()

	a := s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{10, 10}, Size: voplay.Vec2{32, 32}, Tag: "player"})
	b := s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{50, 50}, Size: voplay.Vec2{16, 16}, Tag: "enemy"})
	c := s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{90, 90}, Size: voplay.Vec2{16, 16}, Tag: "enemy"})
	_ = c

	found := s.FindByTag("player")
	assert(found == a, "FindByTag player")
	found = s.FindByTag("enemy")
	assert(found == b, "FindByTag enemy returns first")
	found = s.FindByTag("nonexistent")
	assert(found == nil, "FindByTag nonexistent")
	assert(s.EntityCount() == 3, "EntityCount")
	inside := s.FindInRect(voplay.Rect{0, 0, 60, 60})
	assert(len(inside) == 2, "FindInRect finds entities in rectangle")

	count := 0
	s.ForEach(func(e *scene2d.Entity) {
		count++
	})
	assert(count == 3, "ForEach count")

	all := s.Entities()
	assert(len(all) == 3, "Entities len")
	visible := s.VisibleEntities()
	assert(len(visible) == 3, "VisibleEntities len")

	s.Destroy(b)
	assert(s.EntityCount() == 2, "EntityCount after destroy")
	found = s.FindByTag("enemy")
	assert(found == c, "FindByTag returns next enemy after destroy")

	fmt.Println("  scene queries: ok")
}

func testTilemap() {
	ts := &scene2d.TileSet{Texture: 1, TileW: 32, TileH: 32, Columns: 4}
	tm := scene2d.NewTilemap(ts, 10, 10)

	assert(tm.GetTile(0, 0, 0) == -1, "tilemap default empty")
	assert(tm.GetTile(0, 5, 5) == -1, "tilemap default empty mid")

	tm.SetTile(0, 3, 4, 7)
	assert(tm.GetTile(0, 3, 4) == 7, "SetTile/GetTile")

	tm.Fill(0, 2)
	assert(tm.GetTile(0, 0, 0) == 2, "Fill")
	assert(tm.GetTile(0, 9, 9) == 2, "Fill corner")

	tm.FillRect(0, 2, 2, 3, 3, 5)
	assert(tm.GetTile(0, 2, 2) == 5, "FillRect start")
	assert(tm.GetTile(0, 4, 4) == 5, "FillRect end")
	assert(tm.GetTile(0, 1, 1) == 2, "FillRect outside")

	layer1 := tm.AddLayer()
	assert(layer1 == 1, "AddLayer returns index")
	assert(tm.GetTile(1, 0, 0) == -1, "new layer is empty")

	col, row := tm.WorldToTile(65, 97)
	assert(col == 2 && row == 3, "WorldToTile")
	wx, wy := tm.TileToWorld(2, 3)
	assert(wx == 64 && wy == 96, "TileToWorld")

	assert(tm.PixelWidth() == 320, "PixelWidth")
	assert(tm.PixelHeight() == 320, "PixelHeight")

	d := voplay.NewDrawCtx()
	scene2d.DrawTilemap(d, tm, 0, 0, 0, 320, 320)
	assert(len(d.Bytes()) > 0, "DrawTilemap produces output")

	fmt.Println("  tilemap: ok")
}

func testDrawScene2D() {
	s := scene2d.New()
	spr := scene2d.NewSprite(1, 32, 32)

	s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{100, 100}, Size: voplay.Vec2{32, 32}, Sprite: spr, ZOrder: 2})
	s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{200, 200}, Size: voplay.Vec2{32, 32}, Sprite: spr, ZOrder: 0})
	s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{300, 300}, Size: voplay.Vec2{32, 32}, ZOrder: 1})
	s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{400, 400}, Size: voplay.Vec2{32, 32}, Sprite: spr, ZOrder: 1})

	d := voplay.NewDrawCtx()
	scene2d.DrawScene(d, s, 800, 600)
	assert(len(d.Bytes()) > 0, "DrawScene2D produces output")

	fmt.Println("  draw scene2d: ok")
}

func testDrawOutlines() {
	d := voplay.NewDrawCtx()
	d.DrawRectOutline(10, 10, 100, 50, 2, voplay.White)
	assert(len(d.Bytes()) > 0, "DrawRectOutline produces output")

	d2 := voplay.NewDrawCtx()
	d2.DrawCircleOutline(100, 100, 50, 1, 16, voplay.Red)
	assert(len(d2.Bytes()) > 0, "DrawCircleOutline produces output")

	w, h := voplay.MeasureText("Hello", 16)
	assert(w > 0, "MeasureText width positive")
	assert(h > 0, "MeasureText height positive")

	w2, _ := voplay.MeasureText("", 24)
	assert(w2 == 0, "MeasureText empty string")

	fmt.Println("  outlines + measure: ok")
}

func testPhysics() {
	s := scene2d.New()
	s.Gravity = voplay.Vec2{0, 98.0}

	ball := s.Spawn(scene2d.EntityDesc{
		Position: voplay.Vec2{100, 0},
		Size:     voplay.Vec2{20, 20},
		Physics: &scene2d.Physics{
			Type:     scene2d.Dynamic,
			Collider: scene2d.Box(10, 10),
			Density:  1.0,
			Friction: 0.3,
		},
	})
	assert(ball.Physics != nil, "ball has physics")

	ground := s.Spawn(scene2d.EntityDesc{
		Position: voplay.Vec2{100, 500},
		Size:     voplay.Vec2{400, 20},
		Physics: &scene2d.Physics{
			Type:     scene2d.Static,
			Collider: scene2d.Box(200, 10),
		},
	})
	_ = ground

	for i := 0; i < 30; i++ {
		s.StepAndSyncPhysics(1.0 / 60.0)
	}

	assert(ball.Position().Y > 0, "ball fell due to gravity")
	v := ball.Velocity()
	assert(v.Y > 0, "ball has downward velocity")

	s.Destroy(ball)
	assert(s.EntityCount() == 1, "entity removed after destroy")

	fmt.Println("  physics: ok")
}

func testEntityHelpers() {
	s := scene2d.New()
	a := s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{10, 20}, Size: voplay.Vec2{30, 40}})
	b := s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{15, 25}, Size: voplay.Vec2{30, 40}})

	c := a.Center()
	assert(c.X == 10 && c.Y == 20, "Entity2D.Center")

	r := a.Bounds()
	assert(r.X == -5 && r.Y == 0 && r.W == 30 && r.H == 40, "Entity2D.Bounds")

	assert(a.Overlaps(b), "Entity2D.Overlaps (overlapping)")

	dist := a.DistanceTo(b)
	assert(dist > 0, "Entity2D.DistanceTo > 0")

	far := s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{1000, 1000}, Size: voplay.Vec2{10, 10}})
	assert(!a.Overlaps(far), "Entity2D.Overlaps (non-overlapping)")

	a.SetPosition(100, 200)
	assert(a.Center().X == 100 && a.Center().Y == 200, "Entity2D.SetPosition")

	nearby := s.FindInRadius(100, 200, 50)
	assert(len(nearby) >= 1, "FindInRadius finds nearby entity")
	farAway := s.FindInRadius(-9999, -9999, 1)
	assert(len(farAway) == 0, "FindInRadius returns empty for distant point")

	s.SetSpatialCellSize(32)
	a.SetPosition(300, 300)
	insideAfterMove := s.FindInRect(voplay.Rect{250, 250, 100, 100})
	assert(len(insideAfterMove) >= 1, "FindInRect sees moved entity after spatial rebuild")

	fmt.Println("  entity helpers: ok")
}

func testSceneHierarchy() {
	s := scene2d.New()
	child := s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{5, 0}, Size: voplay.Vec2{10, 10}, Tag: "child"})
	parent := s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{10, 20}, Size: voplay.Vec2{20, 20}, Tag: "parent"})
	child.SetParent(parent, false)
	assert(child.Parent() == parent, "hierarchy parent assigned")
	assert(len(parent.Children()) == 1, "hierarchy child list")
	assert(child.Position().X == 15 && child.Position().Y == 20, "hierarchy child world position on spawn")
	assert(child.LocalPosition().X == 5 && child.LocalPosition().Y == 0, "hierarchy child local position on spawn")

	parent.SetPosition(20, 30)
	assert(child.Position().X == 25 && child.Position().Y == 30, "hierarchy child follows parent translation")

	parent.SetScale(2, 2)
	assert(child.Position().X == 30 && child.Position().Y == 30, "hierarchy child follows parent scale")

	inside := s.FindInRect(voplay.Rect{25, 25, 20, 20})
	assert(len(inside) == 2, "hierarchy spatial query includes parent and child")

	child.Detach(true)
	assert(child.Parent() == nil, "hierarchy detach clears parent")
	assert(child.Position().X == 30 && child.Position().Y == 30, "hierarchy detach keepWorld keeps world position")
	assert(child.LocalPosition().X == 30 && child.LocalPosition().Y == 30, "hierarchy detach keepWorld rewrites local position")

	grandchild := s.Spawn(scene2d.EntityDesc{Position: voplay.Vec2{1, 1}, Size: voplay.Vec2{4, 4}, Tag: "grandchild"})
	grandchild.SetParent(parent, false)
	assert(grandchild.Parent() == parent, "hierarchy second child parent assigned")
	s.Destroy(parent)
	assert(s.FindByTag("parent") == nil, "hierarchy destroy removes parent")
	assert(s.FindByTag("grandchild") == nil, "hierarchy destroy removes descendants")
	assert(s.EntityCount() == 1, "hierarchy destroy leaves detached child alive")

	fmt.Println("  scene hierarchy: ok")
}

func testColorHelpers() {
	c := voplay.Red

	c2 := c.WithAlpha(0.5)
	assert(c2.R == 1 && c2.G == 0 && c2.B == 0 && c2.A == 0.5, "Color.WithAlpha")

	c3 := voplay.Black.Lerp(voplay.White, 0.5)
	assert(c3.R == 0.5 && c3.G == 0.5 && c3.B == 0.5, "Color.Lerp midpoint")

	c4 := voplay.Red.Lerp(voplay.Blue, 0)
	assert(c4.R == 1 && c4.B == 0, "Color.Lerp at 0")
	c5 := voplay.Red.Lerp(voplay.Blue, 1)
	assert(c5.R == 0 && c5.B == 1, "Color.Lerp at 1")

	fmt.Println("  color helpers: ok")
}

func testSceneClear() {
	s := scene2d.New()
	s.Spawn(scene2d.EntityDesc{Tag: "a", Size: voplay.Vec2{10, 10}})
	s.Spawn(scene2d.EntityDesc{Tag: "b", Size: voplay.Vec2{10, 10}})
	s.Spawn(scene2d.EntityDesc{Tag: "a", Size: voplay.Vec2{10, 10}})

	all := s.FindAllByTag("a")
	assert(len(all) == 2, "FindAllByTag returns 2")
	none := s.FindAllByTag("x")
	assert(len(none) == 0, "FindAllByTag returns 0 for missing")

	assert(s.EntityCount() == 3, "3 entities before clear")
	s.Clear()
	assert(s.EntityCount() == 0, "0 entities after clear")

	s.Spawn(scene2d.EntityDesc{Tag: "c", Size: voplay.Vec2{5, 5}})
	assert(s.EntityCount() == 1, "1 entity after re-spawn")
	assert(len(s.VisibleEntities()) == 1, "VisibleEntities remains active+visible list")

	fmt.Println("  scene clear: ok")
}

func testContacts() {
	s := scene2d.New()
	s.Spawn(scene2d.EntityDesc{Size: voplay.Vec2{10, 10}})
	c := s.Contacts()
	assert(c == nil, "Contacts nil without physics")

	fmt.Println("  contacts: ok")
}

func testAudio() {
	_, err := voplay.LoadAudio("/nonexistent/audio.wav")
	assert(err != nil, "LoadAudio nonexistent file returns error")

	voplay.SetSFXVolume(0.5)
	voplay.SetMusicVolume(0.8)
	voplay.StopMusic()
	voplay.PauseMusic()
	voplay.ResumeMusic()
	voplay.AudioClipID(0).Free()

	fmt.Println("  audio: ok")
}

func testDrawEncoding() {
	d := voplay.NewDrawCtx()
	d.SetLayer(42)
	buf := d.Bytes()
	assert(buf[0] == 0x05, "SetLayer opcode is 0x05")
	assert(buf[1] == 42, "SetLayer z low byte")
	assert(buf[2] == 0, "SetLayer z high byte")

	d2 := voplay.NewDrawCtx()
	d2.Clear(1, 0, 0, 1)
	buf2 := d2.Bytes()
	assert(buf2[0] == 0x01, "Clear opcode is 0x01")
	assert(len(buf2) == 1+4*4, "Clear is 1 opcode + 4 f32")

	d3 := voplay.NewDrawCtx()
	d3.DrawRect(10, 20, 100, 50, voplay.Red)
	buf3 := d3.Bytes()
	assert(buf3[0] == 0x11, "DrawRect opcode is 0x11")
	assert(len(buf3) == 1+8*4, "DrawRect is 1 opcode + 8 f32")

	d4 := voplay.NewDrawCtx()
	d4.SetLayer(300)
	buf4 := d4.Bytes()
	assert(buf4[0] == 0x05, "SetLayer opcode")
	assert(buf4[1] == 0x2C, "SetLayer 300 low byte")
	assert(buf4[2] == 0x01, "SetLayer 300 high byte")

	d5 := voplay.NewDrawCtx()
	d5.SetLayer(0)
	d5.DrawRect(0, 0, 10, 10, voplay.Red)
	d5.SetLayer(5)
	d5.DrawRect(0, 0, 20, 20, voplay.Blue)
	buf5 := d5.Bytes()
	assert(buf5[0] == 0x05, "first opcode is SetLayer")
	setLayerSize := 1 + 2
	drawRectSize := 1 + 8*4
	secondSetLayerStart := setLayerSize + drawRectSize
	assert(buf5[secondSetLayerStart] == 0x05, "second SetLayer opcode at correct offset")
	assert(buf5[secondSetLayerStart+1] == 5, "second SetLayer z=5")

	fmt.Println("  draw encoding: ok")
}

func testScene3D() {
	s := scene3d.New()
	assert(s.Camera.Fov == 60, "Scene3D default camera fov")
	assert(s.Camera.Near == 0.1, "Scene3D default camera near")
	assert(s.Camera.Far == 1000, "Scene3D default camera far")

	n1 := s.Spawn(scene3d.Entity{Tag: "cube", Model: 1})
	assert(n1.Visible, "Node3D visible after spawn")
	assert(n1.Scale.X == 1 && n1.Scale.Y == 1 && n1.Scale.Z == 1, "Node3D default scale")
	assert(n1.Rotation.W == 1, "Node3D default rotation is identity")
	assert(s.EntityCount() == 1, "Scene3D has 1 node")

	n2 := s.Spawn(scene3d.Entity{Tag: "sphere", Model: 2})
	assert(s.EntityCount() == 2, "Scene3D has 2 nodes")

	cube := s.FindByTag("cube")
	assert(cube == n1, "FindByTag cube")
	none := s.FindByTag("missing")
	assert(none == nil, "FindByTag returns nil for missing")
	all := s.FindAllByTag("cube")
	assert(len(all) == 1, "FindAllByTag cube")

	count := 0
	s.ForEach(func(n *scene3d.Entity) { count++ })
	assert(count == 2, "ForEach visits all nodes")
	assert(len(s.Entities()) == 2, "Entities count")
	assert(len(s.VisibleEntities()) == 2, "VisibleEntities count")

	assert(len(s.Lights) == 0, "No lights initially")
	s.AddLight(scene3d.Light{
		Type:      scene3d.DirectionalLight,
		Direction: voplay.Vec3{0, -1, 0},
		Color:     voplay.White,
		Intensity: 1,
	})
	assert(len(s.Lights) == 1, "1 light after AddLight")
	s.ClearLights()
	assert(len(s.Lights) == 0, "0 lights after ClearLights")

	s.Destroy(n1)
	assert(s.EntityCount() == 1, "1 node after destroy")

	s.Clear()
	assert(s.EntityCount() == 0, "0 nodes after clear")

	s.Spawn(scene3d.Entity{Tag: "new"})
	assert(s.EntityCount() == 1, "1 node after re-spawn")

	_ = n2
	fmt.Println("  scene3d: ok")
}

func testMath3D() {
	v := voplay.Vec3{1, 2, 3}
	n := v.Negate()
	assert(n.X == -1 && n.Y == -2 && n.Z == -3, "Vec3.Negate")

	q := voplay.QuatIdentity()
	assert(q.W == 1 && q.X == 0 && q.Y == 0 && q.Z == 0, "QuatIdentity")

	qi := q.Inverse()
	assert(qi.W == 1 && qi.X == 0, "QuatIdentity.Inverse")

	rot := voplay.QuatFromAxisAngle(voplay.Vec3{0, 1, 0}, 1.5707963267948966)
	rotated := rot.RotateVec3(voplay.Vec3{1, 0, 0})
	assert(rotated.X < 0.001 && rotated.X > -0.001, "RotateVec3 x near 0")
	assert(rotated.Z < -0.999, "RotateVec3 z near -1")

	qe := voplay.QuatFromEuler(0.5, 0.3, 0.1)
	axis, angle := qe.ToAxisAngle()
	assert(angle > 0, "ToAxisAngle angle > 0")
	assert(axis.Length() > 0.99, "ToAxisAngle axis is unit")

	qa := voplay.QuatIdentity()
	qb := voplay.QuatFromAxisAngle(voplay.Vec3{0, 0, 1}, 1.0)
	s0 := qa.Slerp(qb, 0)
	assert(s0.W > 0.999, "Slerp t=0 returns start")
	s1 := qa.Slerp(qb, 1)
	assert(s1.W-qb.W < 0.001 && s1.W-qb.W > -0.001, "Slerp t=1 returns end")

	fmt.Println("  math3d: ok")
}

func testDraw3DEncoding() {
	d := voplay.NewDrawCtx()
	cam := scene3d.Camera{
		Position: voplay.Vec3{0, 5, 10},
		Target:   voplay.Vec3{0, 0, 0},
		Up:       voplay.Vec3{0, 1, 0},
		Fov:      60,
		Near:     0.1,
		Far:      1000,
	}
	d.SetCamera3D(cam.Position, cam.Target, cam.Up, cam.Fov, cam.Near, cam.Far)
	assert(len(d.Bytes()) > 0, "SetCamera3D encodes bytes")

	lights := []voplay.LightDesc{
		{
			Type:      voplay.DirectionalLight,
			Direction: voplay.Vec3{0, -1, 0},
			Color:     voplay.White,
			Intensity: 1,
		},
	}
	d.SetLights3D(voplay.Color{R: 0.2, G: 0.2, B: 0.2, A: 1}, lights)
	d.DrawModel(1, voplay.Vec3{0, 0, 0}, voplay.QuatIdentity(), voplay.Vec3{1, 1, 1})

	buf := d.Bytes()
	assert(buf[0] == 0x03, "first opcode is SetCamera3D")
	assert(len(buf) > 80, "3D draw stream has substantial data")

	s := scene3d.New()
	s.Spawn(scene3d.Entity{Model: 1, Position: voplay.Vec3{0, 0, 0}})
	s.AddLight(scene3d.Light{
		Type:      scene3d.DirectionalLight,
		Direction: voplay.Vec3{0, -1, 0},
		Color:     voplay.White,
		Intensity: 1,
	})
	d2 := voplay.NewDrawCtx()
	scene3d.DrawScene(d2, s)
	assert(len(d2.Bytes()) > 0, "DrawScene3D encodes data")

	fmt.Println("  draw3d encoding: ok")
}

func testCamera3DMethods() {
	cam := scene3d.Camera{
		Position: voplay.Vec3{0, 5, 10},
		Target:   voplay.Vec3{0, 0, 0},
		Up:       voplay.Vec3{0, 1, 0},
		Fov:      60,
		Near:     0.1,
		Far:      1000,
	}

	cam.LookAt(voplay.Vec3{1, 2, 3}, voplay.Vec3{4, 5, 6})
	assert(cam.Position.X == 1 && cam.Position.Y == 2 && cam.Position.Z == 3, "Camera3D.LookAt position")
	assert(cam.Target.X == 4 && cam.Target.Y == 5 && cam.Target.Z == 6, "Camera3D.LookAt target")

	cam.Up = voplay.Vec3{0, 1, 0}
	cam.Orbit(voplay.Vec3{0, 0, 0}, 10, 0, 0)
	assert(cam.Target.X == 0 && cam.Target.Y == 0 && cam.Target.Z == 0, "Camera3D.Orbit target stays at center")
	dist := cam.Position.Length()
	assert(dist > 9.9 && dist < 10.1, "Camera3D.Orbit distance preserved")

	cam.LookAt(voplay.Vec3{0, 0, 5}, voplay.Vec3{0, 0, 0})
	cam.Up = voplay.Vec3{0, 1, 0}
	cam.Fov = 60
	origin, dir := cam.ScreenToRay(400, 300, 800, 600)
	assert(origin.X == 0 && origin.Y == 0 && origin.Z == 5, "ScreenToRay origin is camera position")
	assert(dir.Z < 0, "ScreenToRay center ray points forward")

	fmt.Println("  camera3d methods: ok")
}

func testScene3DAmbient() {
	s := scene3d.New()
	assert(s.Ambient.R == 0.1, "Scene3D default ambient R")
	assert(s.Ambient.A == 1, "Scene3D default ambient A")

	s.Ambient = voplay.Color{0.3, 0.3, 0.5, 1}
	assert(s.Ambient.B == 0.5, "Scene3D custom ambient B")

	s.Spawn(scene3d.Entity{Model: 1, Position: voplay.Vec3{0, 0, 0}})
	s.AddLight(scene3d.Light{
		Type:      scene3d.DirectionalLight,
		Direction: voplay.Vec3{0, -1, 0},
		Color:     voplay.White,
		Intensity: 1,
	})
	d := voplay.NewDrawCtx()
	scene3d.DrawScene(d, s)
	buf := d.Bytes()
	assert(len(buf) > 0, "DrawScene3D with custom ambient encodes data")

	fmt.Println("  scene3d ambient: ok")
}

func testScene3DPhysicsConfig() {
	s := scene3d.New()

	node := s.Spawn(scene3d.Entity{
		Position: voplay.Vec3{0, 10, 0},
		Model:    1,
	})
	assert(node.Position.Y == 10, "Node3D spawned at correct position")
	assert(s.EntityCount() == 1, "Scene3D has 1 node after spawn")

	ground := s.Spawn(scene3d.Entity{
		Position: voplay.Vec3{0, 0, 0},
		Model:    2,
	})
	assert(s.EntityCount() == 2, "Scene3D has 2 nodes")

	ball := s.Spawn(scene3d.Entity{
		Position: voplay.Vec3{5, 5, 0},
	})
	assert(s.EntityCount() == 3, "Scene3D has 3 nodes")
	_ = ball

	node.SetPosition(voplay.Vec3{0, 20, 0})
	assert(node.Position.Y == 20, "SetPosition updates Position immediately")

	node.ApplyForce(voplay.Vec3{0, 100, 0})
	node.ApplyImpulse(voplay.Vec3{10, 0, 0})
	node.SetVelocity(voplay.Vec3{1, 2, 3})

	s.Destroy(ground)
	assert(s.EntityCount() == 2, "Scene3D has 2 nodes after destroy")

	s.Clear()
	assert(s.EntityCount() == 0, "Scene3D empty after clear")

	box := scene3d.Box(1, 2, 3)
	assert(box.Kind() == scene3d.ColliderBox, "Box3D collider kind")
	sphere := scene3d.Sphere(0.5)
	assert(sphere.Kind() == scene3d.ColliderSphere, "Sphere collider kind")
	capsule := scene3d.Capsule(1.0, 0.3)
	assert(capsule.Kind() == scene3d.ColliderCapsule, "Capsule collider kind")

	p := &scene3d.Physics{
		Type:        scene3d.Dynamic,
		Collider:    scene3d.Box(1, 1, 1),
		Density:     2.0,
		Friction:    0.5,
		Restitution: 0.3,
	}
	assert(p.Density == 2.0, "Physics3D density")
	assert(p.Friction == 0.5, "Physics3D friction")

	fmt.Println("  scene3d physics config: ok")
}

func testPointerDelta() {
	inp := voplay.NewInputState()
	dx, dy := inp.PointerDelta()
	assert(dx == 0 && dy == 0, "PointerDelta initial zero")
	wx, wy := inp.WorldPointerPos(0, 0, 1, 0, 800, 600)
	assert(wx == -400 && wy == -300, "WorldPointerPos default top-left")

	fmt.Println("  pointer delta: ok")
}

func testScene3DContacts() {
	s := scene3d.New()
	contacts := s.Contacts()
	assert(contacts == nil, "Contacts empty on new scene")

	fmt.Println("  scene3d contacts: ok")
}

func testRayCastHitTypes() {
	hit2d := scene2d.RayCastHit{
		Point:    voplay.Vec2{10, 20},
		Normal:   voplay.Vec2{0, -1},
		Distance: 5.5,
	}
	assert(hit2d.Point.X == 10, "RayCastHit2D point")
	assert(hit2d.Normal.Y == -1, "RayCastHit2D normal")
	assert(hit2d.Distance == 5.5, "RayCastHit2D distance")

	hit3d := scene3d.RayCastHit{
		Point:    voplay.Vec3{1, 2, 3},
		Normal:   voplay.Vec3{0, 1, 0},
		Distance: 10.0,
	}
	assert(hit3d.Point.Z == 3, "RayCastHit3D point")
	assert(hit3d.Normal.Y == 1, "RayCastHit3D normal")
	assert(hit3d.Distance == 10.0, "RayCastHit3D distance")

	fmt.Println("  raycast hit types: ok")
}

func testDrawBillboard() {
	d := voplay.NewDrawCtx()
	cam := scene3d.Camera{
		Position: voplay.Vec3{0, 5, 10},
		Target:   voplay.Vec3{0, 0, 0},
		Up:       voplay.Vec3{0, 1, 0},
		Fov:      60,
		Near:     0.1,
		Far:      1000,
	}
	d.SetCamera3D(cam.Position, cam.Target, cam.Up, cam.Fov, cam.Near, cam.Far)
	d.DrawBillboard(1, 0, 0, 32, 32, voplay.Vec3{0, 2, 0}, 1.0, 0.5)
	buf := d.Bytes()
	assert(len(buf) > 0, "DrawBillboard encodes data")

	fmt.Println("  draw billboard: ok")
}

func testScene3DRayCast() {
	s := scene3d.New()
	hit := s.RayCast(voplay.Vec3{0, 10, 0}, voplay.Vec3{0, -1, 0}, 100)
	assert(hit == nil, "RayCast nil on empty scene")

	result := s.QueryAABB(voplay.Vec3{-1, -1, -1}, voplay.Vec3{1, 1, 1})
	assert(result == nil, "QueryAABB nil on non-physics scene")

	fmt.Println("  scene3d raycast: ok")
}

func testScene2DRayCastQueryRect() {
	s := scene2d.New()
	hit := s.RayCast(voplay.Vec2{0, 0}, voplay.Vec2{1, 0}, 100)
	assert(hit == nil, "RayCast nil on non-physics scene")

	result := s.QueryRect(voplay.Rect{0, 0, 100, 100})
	assert(result == nil, "QueryRect nil on non-physics scene")

	fmt.Println("  scene2d raycast/queryrect: ok")
}

func assert(cond bool, msg string) {
	if !cond {
		panic("assertion failed: " + msg)
	}
}
