// Native shapes test: opens a window and renders 2D shapes via voplay.Run.
// Run with: ./d.py run tests/voplay_native/main.vo
package main

import (
	"fmt"
	"github.com/vo-lang/voplay"
)

type shapesState struct {
	t float64
}

func main() {
	voplay.Run(voplay.Game{
		Width:        800,
		Height:       600,
		Title:        "VoPlay Native Shapes",
		InitialState: &shapesState{},
	})
}

func (s *shapesState) Enter(g *voplay.GameCtx) {
	fmt.Println("Native shapes demo initialized")
}

func (s *shapesState) Update(g *voplay.GameCtx, dt float64) {
	s.t += dt
}

func (s *shapesState) Draw(g *voplay.GameCtx) {
	// Clear to dark blue
	g.Draw.Clear(0.1, 0.1, 0.3, 1.0)

	// Red rectangle
	g.Draw.DrawRect(50, 50, 200, 120, voplay.Red)

	// Green circle
	g.Draw.DrawCircle(400, 200, 80, voplay.Green)

	// Yellow line
	g.Draw.DrawLine(100, 400, 600, 350, 4, voplay.Yellow)

	// Semi-transparent white rectangle
	g.Draw.DrawRect(300, 100, 250, 180, voplay.Color{1, 1, 1, 0.3})

	// Thick cyan line at bottom
	g.Draw.DrawLine(50, 500, 750, 500, 8, voplay.Cyan)
}
