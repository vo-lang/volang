package main

type Empty struct{}

func main() {
	arr := [1]Empty{}
	i := 1
	recovered := false
	func() {
		defer func() {
			if recover() != nil {
				recovered = true
			}
		}()
		i, arr[i] = 0, Empty{}
	}()
	assert(recovered, "empty struct array index snapshot must preserve bounds panic")
	assert(i == 0, "earlier assignment should commit before later lhs store panic")
	println("2026_05_31_stack_array_empty_struct_index_snapshot: ok")
}
