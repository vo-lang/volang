package main

func assert(ok bool, msg string) {
	if !ok {
		panic(msg)
	}
}

func largeFrameCallee(x int) int {
	var pad [600]int
	pad[0] = x + 11
	pad[599] = x + 29
	return pad[0] + pad[599] - x
}

func warmLargeFrameCallee() {
	for i := 0; i < 1005; i++ {
		_ = largeFrameCallee(0)
	}
}

func osrCaller(n int) int {
	sum := 0
	for i := 0; i < n; i++ {
		sum = sum + largeFrameCallee(7)
	}
	return sum
}

func main() {
	warmLargeFrameCallee()
	assert(osrCaller(3) == 141, "OSR large-frame direct call must fall back through VM route")
}
