package main

import (
 	"io"
	"net"
	"net/http"
 	"strconv"
	"time"
)

// Minimal reproduction: http.Server + http.Get combo fails after ~100 requests in JIT mode.
// The program exits prematurely when JIT compilation triggers for some function.
// Works fine in VM mode.

func main() {
	mux := http.NewServeMux()
	mux.HandleFunc("/", func(w http.ResponseWriter, r *http.Request) {
		w.Write([]byte("OK"))
	})
	ln, err := net.Listen("tcp", "127.0.0.1:0")
	if err != nil {
		panic("Listen failed: " + err.Error())
	}
	addr := ln.Addr().String()
	srv := &http.Server{Handler: mux}
	serverDone := make(chan error, 1)
	go func() {
		err := srv.Serve(ln)
		if err != nil && err.Error() != http.ErrServerClosed.Error() {
			serverDone <- err
			return
		}
		serverDone <- nil
	}()
	client := &http.Client{Timeout: 2 * time.Second}

	for i := 0; i < 105; i++ {
		resp, err := client.Get("http://" + addr + "/")
		if err != nil {
			panic("http.Get failed at " + strconv.Itoa(i) + ": " + err.Error())
		}
		body, err := io.ReadAll(resp.Body)
		if err != nil {
			panic("ReadAll failed at " + strconv.Itoa(i) + ": " + err.Error())
		}
		resp.Body.Close()
		if string(body) != "OK" {
			panic("unexpected response body at " + strconv.Itoa(i) + ": '" + string(body) + "'")
		}
	}

	srv.Close()
	if err := <-serverDone; err != nil {
		panic("server failed: " + err.Error())
	}
	println("[VO:OK]")
}
