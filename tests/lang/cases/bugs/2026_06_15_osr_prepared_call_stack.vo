package main

func assert(ok bool, msg string) {
	if !ok {
		panic(msg)
	}
}

func warmPreparedClosure(f func(int) int) {
	for i := 0; i < 150; i++ {
		_ = f(i)
	}
}

func osrPreparedClosureLoop(n int, f func(int) int) int {
	total := 0
	marker := 3
	for i := 0; i < n; i++ {
		total += f(i)
		marker += 5
	}
	return total + marker
}

func main() {
	f := func(x int) int {
		var pad [9000]int
		pad[0] = x + 10
		pad[8999] = x + 20
		return pad[0] + pad[8999] - x
	}
	warmPreparedClosure(f)
	assert(osrPreparedClosureLoop(120, f) == 11343, "OSR prepared closure call must refresh stack base before caller local writes")
}
