package main

type Huge struct {
	f00 int
	f01 int
	f02 int
	f03 int
	f04 int
	f05 int
	f06 int
	f07 int
	f08 int
	f09 int
	f10 int
	f11 int
	f12 int
	f13 int
	f14 int
	f15 int
	f16 int
	f17 int
	f18 int
	f19 int
	f20 int
	f21 int
	f22 int
	f23 int
	f24 int
	f25 int
	f26 int
	f27 int
	f28 int
	f29 int
	f30 int
	f31 int
	f32 int
}

var hugeSink *Huge

func mustPanic(f func(), msg string) {
	panicked := false
	func() {
		defer func() {
			if recover() != nil {
				panicked = true
			}
		}()
		f()
	}()
	assert(panicked, msg)
}

func arrayAddrOutOfBoundsLoop() {
	arr := [1]Huge{}
	idx := 1
	for i := 0; i < 80; i++ {
		if i == 79 {
			hugeSink = &arr[idx]
		}
	}
}

func main() {
	mustPanic(arrayAddrOutOfBoundsLoop, "array address-of out of bounds must panic")
	println("jit_array_addr_oob_panic: ok")
}
