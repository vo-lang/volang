// Regression: a pointer receiver on a named slice is rejected cleanly.
package main

import (
	"fmt"
)

type IntSlice []int

func (s *IntSlice) Append(v int) {
	*s = append(*s, v)
}

func main() {
	s := IntSlice{1, 2, 3}
	s.Append(4)
	assert(len(s) == 4, "len should be 4")
	fmt.Println("bug_ptr_recv_named_slice: ok")
}
