// Test: Closing a home port must notify a remote sender.
package main

import (
	"time"
)

func waitBool(ch port bool, label string) bool {
	done := false
	value := false
	for i := 0; i < 200 && !done; i += 1 {
		select {
			case value = <-ch:
				done = true
			default:
				time.Sleep(5 * time.Millisecond)
		}
	}
	assert(done, label)
	return value
}

func main() {
	testRemoteSendOnClosedPanics()
}

// Remote send on a closed channel must panic (recovered).
func testRemoteSendOnClosedPanics() {
	islandA := make(island)
	ch := make(port int, 1)
	result := make(port bool, 1)
	close(ch) // close on main
	go @(islandA) func(data port<- int, out port<- bool) {
		defer func() {
			if r := recover(); r != nil {
				out <- true
			}
		}()
		data <- 999
		out <- false // should not reach
	}(ch, result)
	panicked := waitBool(result, "testRemoteSendOnClosedPanics: timed out")
	assert(panicked, "remote send on closed channel must panic")
}
