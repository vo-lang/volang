package main

type Pair struct {
	Left port<- int
	Right port<- int
}

type PairPtr struct {
	Left port<- int
	Right port<- int
}

func main() {
	testStructNestedSendCapabilities()
	testSliceNestedSendCapabilities()
	testMapNestedSendCapabilities()
	testPointerNestedSendCapabilities()
}

func testStructNestedSendCapabilities() {
	i := make(island)
	inner := make(port int, 1)
	eq := make(port bool, 1)
	pair := Pair{Left: inner, Right: inner}
	go @(i) func(value Pair, out port<- bool) {
		out <- (value.Left == value.Right)
		value.Left <- 101
	}(pair, eq)
	assert(<-eq, "struct nested send capabilities must preserve alias identity")
	assert(<-inner == 101, "struct nested send capability must work")
}

func testSliceNestedSendCapabilities() {
	i := make(island)
	inner := make(port int, 1)
	eq := make(port bool, 1)
	items := []port<- int{inner, inner}
	go @(i) func(value []port<- int, out port<- bool) {
		out <- (value[0] == value[1])
		value[1] <- 202
	}(items, eq)
	assert(<-eq, "slice nested send capabilities must preserve alias identity")
	assert(<-inner == 202, "slice nested send capability must work")
}

func testMapNestedSendCapabilities() {
	i := make(island)
	inner := make(port int, 1)
	eq := make(port bool, 1)
	items := map[string]port<- int{"left": inner, "right": inner}
	go @(i) func(value map[string]port<- int, out port<- bool) {
		out <- (value["left"] == value["right"])
		value["right"] <- 303
	}(items, eq)
	assert(<-eq, "map nested send capabilities must preserve alias identity")
	assert(<-inner == 303, "map nested send capability must work")
}

func testPointerNestedSendCapabilities() {
	i := make(island)
	inner := make(port int, 1)
	eq := make(port bool, 1)
	pair := &PairPtr{Left: inner, Right: inner}
	go @(i) func(value *PairPtr, out port<- bool) {
		out <- (value.Left == value.Right)
		value.Right <- 404
	}(pair, eq)
	assert(<-eq, "pointer nested send capabilities must preserve alias identity")
	assert(<-inner == 404, "pointer nested send capability must work")
}
