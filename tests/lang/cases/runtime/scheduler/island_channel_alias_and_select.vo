package main

import "time"

type NestedAliasBox struct {
	Inner port int
}

func main() {
	testTransferredChannelAliasIdentity()
	testTransferredNestedChannelAliasAcrossCaptureAndArg()
	testClosedTransferredChannelStaysClosed()
	testRemoteSelectFailsFast()
}

func testTransferredChannelAliasIdentity() {
	i := make(island)
	ch := make(port int, 1)
	eq := make(port bool, 1)

	go @(i) func(a port int, b port int, out port bool) {
		out <- (a == b)
	}(ch, ch, eq)

	done := false
	same := false
	for i := 0; i < 100 && !done; i += 1 {
		select {
		case same = <-eq:
			done = true
		default:
			time.Sleep(5 * time.Millisecond)
		}
	}
	assert(done, "timed out waiting for transferred channel alias result")
	assert(same, "transferred channel aliases must preserve identity")
}

func testTransferredNestedChannelAliasAcrossCaptureAndArg() {
	i := make(island)
	inner := make(port int, 1)
	out := make(port bool, 1)
	captured := NestedAliasBox{Inner: inner}

	go @(i) func(arg NestedAliasBox, result port bool) {
		result <- (captured.Inner == arg.Inner)
		arg.Inner <- 505
	}(captured, out)

	done := false
	same := false
	for i := 0; i < 100 && !done; i += 1 {
		select {
		case same = <-out:
			done = true
		default:
			time.Sleep(5 * time.Millisecond)
		}
	}
	assert(done, "timed out waiting for nested transferred channel alias result")
	assert(same, "nested transferred channel aliases across capture and arg must preserve identity")

	recvDone := false
	value := 0
	for i := 0; i < 100 && !recvDone; i += 1 {
		select {
		case value = <-inner:
			recvDone = true
		default:
			time.Sleep(5 * time.Millisecond)
		}
	}
	assert(recvDone, "timed out waiting for nested transferred channel send")
	assert(value == 505, "nested transferred channel send across capture and arg must work")
}

func testRemoteSelectFailsFast() {
	i := make(island)
	ch := make(port int, 1)
	out := make(port bool, 1)

	go @(i) func(remote port int, result port bool) {
		defer func() {
			if r := recover(); r != nil {
				result <- true
			}
		}()
		select {
		case <-remote:
			result <- false
		default:
			result <- false
		}
	}(ch, out)

	done := false
	recovered := false
	for i := 0; i < 100 && !done; i += 1 {
		select {
		case recovered = <-out:
			done = true
		default:
			time.Sleep(5 * time.Millisecond)
		}
	}
	assert(done, "timed out waiting for remote select result")
	assert(recovered, "remote select should panic and be recovered")
}

func testClosedTransferredChannelStaysClosed() {
	i := make(island)
	ch := make(port int, 1)
	out := make(port bool, 1)
	close(ch)

	go @(i) func(remote port int, result port bool) {
		v, ok := <-remote
		result <- (v == 0 && ok == false)
	}(ch, out)

	done := false
	closedOk := false
	for i := 0; i < 100 && !done; i += 1 {
		select {
		case closedOk = <-out:
			done = true
		default:
			time.Sleep(5 * time.Millisecond)
		}
	}
	assert(done, "timed out waiting for closed transferred channel result")
	assert(closedOk, "closed transferred channel must stay closed")
}
