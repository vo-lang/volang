package main

import (
	"fmt"
)

func deferNilFunc() bool {
	recovered := false
	func() {
		defer func() {
			if r := recover(); r != nil {
				recovered = true
			}
		}()
		var f func()
		defer f()
	}()
	return recovered
}

func main() {
	for i := 0; i < 4; i++ {
		assert(deferNilFunc(), "deferred nil func should panic and recover")
	}
	fmt.Println("defer_nil_func_recover: ok")
}
