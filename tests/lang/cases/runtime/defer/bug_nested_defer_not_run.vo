// Regression: a deferred function must run its own defers before returning.
package main

import (
	"fmt"
)

func nestedDefer() (val int) {
	defer func() {
		defer func() {
			val += 1
		}()
		val += 10
	}()
	val = 100
	return
}

func main() {
	r := nestedDefer()
	assert(r == 111, "nestedDefer should return 111, got ", r)
	fmt.Println("bug_nested_defer_not_run: ok")
}
