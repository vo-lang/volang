package main

type Adder interface {
	Add(int) int
}

type Inc struct {
	base int
}

type Mul struct {
	factor int
}

func (a *Inc) Add(x int) int {
	return x + a.base
}

func (m *Mul) Add(x int) int {
	return x * m.factor
}

func apply(adder Adder, x int) int {
	return adder.Add(x)
}

func runMonomorphic() int {
	var adder Adder = &Inc{base: 7}
	sum := 0
	for i := 0; i < 128; i++ {
		sum += apply(adder, i)
	}
	return sum
}

func runPolymorphic() int {
	sum := 0
	for i := 0; i < 128; i++ {
		if i%2 == 0 {
			var adder Adder = &Inc{base: 3}
			sum += apply(adder, i)
		} else {
			var adder Adder = &Mul{factor: 2}
			sum += apply(adder, i)
		}
	}
	return sum
}

func expectedMonomorphic() int {
	sum := 0
	for i := 0; i < 128; i++ {
		sum += i + 7
	}
	return sum
}

func expectedPolymorphic() int {
	sum := 0
	for i := 0; i < 128; i++ {
		if i%2 == 0 {
			sum += i + 3
		} else {
			sum += i * 2
		}
	}
	return sum
}

func main() {
	mono := runMonomorphic()
	poly := runPolymorphic()
	assert(mono == expectedMonomorphic(), "monomorphic interface call mismatch")
	assert(poly == expectedPolymorphic(), "polymorphic interface call mismatch")
	println("PASS")
}
