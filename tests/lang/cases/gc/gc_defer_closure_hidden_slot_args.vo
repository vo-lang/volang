package main

import (
	"fmt"
)

type Box struct {
	value int
	next *Box
}

var sink int

func churn(seed int) {
	for i := 0; i < 2000; i++ {
		_ = &Box{value: seed + i}
	}
}

func runOnce(seed int) {
	captured := seed
	take := func(p *Box, a any) {
		q := a.(*Box)
		sink += p.value + q.value + captured
	}
	p := &Box{value: 10 + seed}
	q := &Box{value: 20 + seed, next: p}
	func() {
		defer take(p, q)
		churn(seed)
	}()
}

func main() {
	for i := 0; i < 16; i++ {
		runOnce(i)
	}
	expected := 0
	for i := 0; i < 16; i++ {
		expected += (10 + i) + (20 + i) + i
	}
	assert(sink == expected, "defer closure pointer/interface args should survive GC")
	fmt.Println("gc_defer_closure_hidden_slot_args: ok")
}
