package main

import (
	"net"
	"net/http"
	"io"
	"time"
)

func main() {
	mux := http.NewServeMux()
	mux.HandleFunc("/get", func(w http.ResponseWriter, r *http.Request) {
		w.Write([]byte("client-ok"))
	})

	ln, err := net.Listen("tcp", "127.0.0.1:0")
	if err != nil {
		panic("Listen failed: " + err.Error())
	}
	addr := ln.Addr().String()
	srv := &http.Server{Handler: mux}
	done := make(chan error, 1)
	go func() {
		err := srv.Serve(ln)
		if err != nil && err.Error() != http.ErrServerClosed.Error() {
			done <- err
			return
		}
		done <- nil
	}()

	client := &http.Client{Timeout: 2 * time.Second}
	resp, err := client.Get("http://" + addr + "/get")
	if err != nil {
		panic("GET failed: " + err.Error())
	}
	defer resp.Body.Close()

	assert(resp.StatusCode == http.StatusOK)

	body, err := io.ReadAll(resp.Body)
	if err != nil {
		panic("Read body failed: " + err.Error())
	}
	assert(string(body) == "client-ok")

	if err := srv.Close(); err != nil {
		panic("server close failed: " + err.Error())
	}
	if err := <-done; err != nil {
		panic("server failed: " + err.Error())
	}
}
