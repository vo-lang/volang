package main

import (
	"fmt"
	"bytes"
)

func main() {
	fmt.Println("Starting bytes tests...")
	// Test Equal
	a := []byte{1, 2, 3}
	b := []byte{1, 2, 3}
	c := []byte{1, 2, 4}
	assert(bytes.Equal(a, b), "Equal(a, b) should be true")
	assert(!bytes.Equal(a, c), "Equal(a, c) should be false")
	// Test Compare
	assert(bytes.Compare(a, b) == 0, "Compare equal should be 0")
	assert(bytes.Compare(a, c) < 0, "Compare a < c")
	assert(bytes.Compare(c, a) > 0, "Compare c > a")
	// Test Contains
	haystack := []byte{1, 2, 3, 4, 5}
	needle := []byte{2, 3}
	assert(bytes.Contains(haystack, needle), "Contains should find needle")
	assert(!bytes.Contains(haystack, []byte{6, 7}), "Contains should not find missing")
	// Test HasPrefix/HasSuffix
	assert(bytes.HasPrefix(haystack, []byte{1, 2}), "HasPrefix")
	assert(bytes.HasSuffix(haystack, []byte{4, 5}), "HasSuffix")
	// Test Index/LastIndex
	data := []byte{1, 2, 1, 2, 1}
	assert(bytes.Index(data, []byte{1, 2}) == 0, "Index first occurrence")
	assert(bytes.LastIndex(data, []byte{1, 2}) == 2, "LastIndex last occurrence")
	// Test Count
	assert(bytes.Count(data, []byte{1}) == 3, "Count 1s")
	assert(bytes.Count(data, []byte{1, 2}) == 2, "Count 1,2 pairs")
	assert(bytes.Count([]byte("A世"), []byte{}) == 3, "Count empty separator should count UTF-8 sequences plus one")
	// Test IndexByte/LastIndexByte
	assert(bytes.IndexByte(data, 2) == 1, "IndexByte")
	assert(bytes.LastIndexByte(data, 1) == 4, "LastIndexByte")
	// Test ToLower/ToUpper
	upper := []byte{'H', 'E', 'L', 'L', 'O'}
	lower := bytes.ToLower(upper)
	assert(lower[0] == 'h', "ToLower")
	lower2 := []byte{'h', 'e', 'l', 'l', 'o'}
	upper2 := bytes.ToUpper(lower2)
	assert(upper2[0] == 'H', "ToUpper")
	// Test Repeat
	rep := bytes.Repeat([]byte{1, 2}, 3)
	assert(len(rep) == 6, "Repeat length")
	assert(rep[4] == 1, "Repeat content")
	// IndexFunc / LastIndexFunc
	isDigit := func(r rune) bool {
		return r >= '0' && r <= '9'
	}
	assert(bytes.IndexFunc([]byte("abc123"), isDigit) == 3, "IndexFunc digit")
	assert(bytes.IndexFunc([]byte("abc"), isDigit) == -1, "IndexFunc no match")
	assert(bytes.LastIndexFunc([]byte("abc123abc456"), isDigit) == 11, "LastIndexFunc digit")
	lastCalls := 0
	lastDigit := bytes.LastIndexFunc([]byte("abc3x4"), func(r rune) bool {
		lastCalls++
		return r >= '0' && r <= '9'
	})
	assert(lastDigit == 5 && lastCalls == 1, "LastIndexFunc should scan backward and stop at the first match")
	// Title
	titleResult := bytes.Title([]byte("hello world"))
	assert(string(titleResult) == "Hello World", "Title failed")
	assert(len(bytes.Title([]byte{})) == 0, "Title empty")
	assert(string(bytes.Title([]byte("go.go"))) == "Go.Go", "Title ASCII punctuation boundary")
	// Empty separators split at UTF-8 sequence boundaries and preserve a
	// positive-limit remainder.
	unicodeParts := bytes.Split([]byte("A世"), []byte{})
	assert(len(unicodeParts) == 2, "Split empty separator UTF-8 part count")
	assert(string(unicodeParts[0]) == "A" && string(unicodeParts[1]) == "世", "Split empty separator UTF-8 parts")
	limitedParts := bytes.SplitN([]byte("A世B"), []byte{}, 2)
	assert(len(limitedParts) == 2, "SplitN empty separator limit")
	assert(string(limitedParts[0]) == "A" && string(limitedParts[1]) == "世B", "SplitN should retain unsplit remainder")
	invalidParts := bytes.Split([]byte{'A', 0xff, 0xfe, 'B'}, []byte{})
	assert(len(invalidParts) == 4, "Split should treat each invalid UTF-8 byte as one sequence")
	assert(invalidParts[1][0] == 0xff && invalidParts[2][0] == 0xfe, "Split should preserve invalid bytes")
	assert(bytes.SplitN([]byte("x"), []byte{}, 0) == nil, "SplitN n=0 should return nil")
	splitBacking := []byte("a,b")
	splitViews := bytes.Split(splitBacking, []byte(","))
	splitViews[0] = append(splitViews[0], 'x')
	assert(string(splitBacking) == "a,b", "Split results should cap intermediate subslices")
	emptySepBacking := []byte("ab")
	emptySepViews := bytes.Split(emptySepBacking, []byte{})
	emptySepViews[0] = append(emptySepViews[0], 'x')
	assert(string(emptySepBacking) == "ab", "Split empty-separator results should cap intermediate subslices")
	fields := bytes.Fields([]byte(" alpha\u2003beta\u0085gamma "))
	assert(len(fields) == 3, "Fields should recognize Unicode white space")
	assert(string(fields[0]) == "alpha" && string(fields[1]) == "beta" && string(fields[2]) == "gamma", "Fields Unicode content")
	fieldsBacking := []byte("a b")
	fieldViews := bytes.Fields(fieldsBacking)
	fieldViews[0] = append(fieldViews[0], 'x')
	assert(string(fieldsBacking) == "a b", "Fields results should cap each subslice")
	assert(string(bytes.TrimSpace([]byte("\u2003trimmed\u0085"))) == "trimmed", "TrimSpace should recognize Unicode white space")
	assert(bytes.TrimSpace([]byte("\u2003\u0085")) == nil, "TrimSpace all-space result should be nil")
	assert(bytes.TrimLeftFunc([]byte("xxx"), func(r rune) bool {
		return r == 'x'
	}) == nil, "TrimLeftFunc all-match result should be nil")
	assert(bytes.Trim([]byte{}, "") == nil, "Trim non-nil empty input should return nil")
	assert(bytes.TrimLeft([]byte("abba"), "ab") == nil, "TrimLeft all-match result should be nil")
	assert(bytes.TrimRight([]byte("a"), "a") != nil, "TrimRight all-match result should retain a non-nil empty view")
	assert(bytes.Join([][]byte{[]byte{}}, []byte(",")) == nil, "Join single empty element should return nil")
	replacedEmpty := bytes.Replace([]byte("A世"), []byte{}, []byte("-"), -1)
	assert(string(replacedEmpty) == "-A-世-", "Replace empty pattern should use UTF-8 boundaries")
	replacedLimited := bytes.Replace([]byte("A世"), []byte{}, []byte("-"), 2)
	assert(string(replacedLimited) == "-A-世", "Replace empty pattern should honor n")
	replacedInvalid := bytes.Replace([]byte{0xff, 0xfe}, []byte{}, []byte{'x'}, -1)
	assert(bytes.Equal(replacedInvalid, []byte{'x', 0xff, 'x', 0xfe, 'x'}), "Replace should preserve invalid bytes between boundaries")
	assert(bytes.Replace([]byte{}, []byte("x"), nil, -1) == nil, "Replace empty no-match input should return nil")
	assert(bytes.Replace([]byte{}, []byte("x"), nil, 0) == nil, "Replace n=0 empty input should return nil")
	assert(bytes.Replace([]byte{}, []byte{}, nil, -1) != nil, "Replace empty pattern performs an allocated replacement")
	assert(bytes.Replace([]byte("x"), []byte("x"), nil, -1) != nil, "Replace matched empty output should remain non-nil")
	// ToValidUTF8
	validResult := bytes.ToValidUTF8([]byte("hello"), []byte("?"))
	assert(string(validResult) == "hello", "ToValidUTF8 valid input")
	invalidResult := bytes.ToValidUTF8([]byte{'a', 0xff, 0xfe, 'b', 0xff}, []byte("?"))
	assert(bytes.Equal(invalidResult, []byte("a?b?")), "ToValidUTF8 should replace each invalid run once")
	fmt.Println("All bytes tests passed!")
}
