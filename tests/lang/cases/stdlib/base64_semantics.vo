package main

import (
	"bytes"
	"encoding/base64"
	"errors"
	"io"
	"strings"
)

type chunkReader struct {
	data []byte
	pos int
	chunk int
}

func (r *chunkReader) Read(p []byte) (int, error) {
	if r.pos == len(r.data) {
		return 0, io.EOF
	}
	n := r.chunk
	if n > len(p) {
		n = len(p)
	}
	if n > len(r.data) - r.pos {
		n = len(r.data) - r.pos
	}
	copy(p, r.data[r.pos:r.pos + n])
	r.pos += n
	if r.pos == len(r.data) {
		return n, io.EOF
	}
	return n, nil
}

type shortWriter struct{}

func (w *shortWriter) Write(p []byte) (int, error) {
	if len(p) == 0 {
		return 0, nil
	}
	return len(p) - 1, nil
}

type invalidReader struct{}

func (r *invalidReader) Read(p []byte) (int, error) {
	return len(p) + 1, nil
}

type noProgressReader struct{}

func (r *noProgressReader) Read(p []byte) (int, error) {
	return 0, nil
}

func didPanic(f func()) bool {
	panicked := false
	func() {
		defer func() {
			panicked = recover() != nil
		}()
		f()
	}()
	return panicked
}

func assertBytes(got []byte, want string, message string) {
	assert(bytes.Equal(got, []byte(want)), message)
}

func testRFCVectors() {
	vectors := [][]string{
		{"", ""}, {"f", "Zg=="}, {"fo", "Zm8="}, {"foo", "Zm9v"}, {"foob", "Zm9vYg=="},
		{"fooba", "Zm9vYmE="}, {"foobar", "Zm9vYmFy"},
	}
	for _, vector := range vectors {
		encoded := base64.StdEncoding.EncodeToString([]byte(vector[0]))
		assert(encoded == vector[1], "RFC 4648 standard encoding")
		decoded, err := base64.StdEncoding.DecodeString(encoded)
		assert(err == nil, "RFC 4648 standard decoding")
		assertBytes(decoded, vector[0], "RFC 4648 round trip")
		raw := strings.TrimRight(vector[1], "=")
		assert(base64.RawStdEncoding.EncodeToString([]byte(vector[0])) == raw, "raw encoding")
		decoded, err = base64.RawStdEncoding.DecodeString(raw)
		assert(err == nil, "raw decoding")
		assertBytes(decoded, vector[0], "raw round trip")
	}
	url := []byte{0xfb, 0xff, 0xef}
	assert(base64.URLEncoding.EncodeToString(url) == "-__v", "URL alphabet")
	decoded, err := base64.URLEncoding.DecodeString("-__v")
	assert(err == nil && bytes.Equal(decoded, url), "URL decoding")
}

func testCustomEncoding() {
	alphabet := "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz-_"
	enc := base64.NewEncoding(alphabet)
	input := []byte("custom alphabet")
	encoded := enc.EncodeToString(input)
	decoded, err := enc.DecodeString(encoded)
	assert(err == nil && bytes.Equal(decoded, input), "custom alphabet round trip")
	dot := enc.WithPadding('.')
	encoded = dot.EncodeToString([]byte("x"))
	assert(strings.HasSuffix(encoded, ".."), "custom padding output")
	decoded, err = dot.DecodeString(encoded)
	assert(err == nil && string(decoded) == "x", "custom padding input")
	assert(didPanic(func() {
		_ = base64.NewEncoding("short")
	}), "short alphabet must panic")
	assert(didPanic(func() {
		_ = base64.NewEncoding(strings.Repeat("A", 64))
	}), "duplicate alphabet must panic")
	assert(didPanic(func() {
		_ = base64.NewEncoding("ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+\n")
	}), "newline alphabet must panic")
	assert(didPanic(func() {
		_ = enc.WithPadding('\n')
	}), "newline padding must panic")
	assert(didPanic(func() {
		_ = enc.WithPadding('0')
	}), "alphabet padding must panic")
}

func testMalformedInput() {
	bad := []string{"A", "Zg", "Zg=", "=AAA", "Z===", "Zg==x", "Zm$v"}
	for _, input := range bad {
		_, err := base64.StdEncoding.DecodeString(input)
		assert(err != nil, "malformed padded input must fail")
		assert(errors.Is(err, base64.ErrCorruptInput), "corruption sentinel compatibility")
	}
	_, err := base64.RawStdEncoding.DecodeString("Zg==")
	assert(err != nil, "raw encoding must reject padding")
	decoded, err := base64.StdEncoding.DecodeString("Zm9v\r\nYmFy")
	assert(err == nil, "CR and LF must be ignored")
	assertBytes(decoded, "foobar", "newline decoding")
	decoded, err = base64.StdEncoding.DecodeString("/x==")
	assert(err == nil && len(decoded) == 1 && decoded[0] == 0xff, "non-strict trailing bits")
	_, err = base64.StdEncoding.Strict().DecodeString("/x==")
	assert(err != nil, "strict mode must reject non-zero trailing bits")
	_, err = base64.StdEncoding.Strict().DecodeString("//9=")
	assert(err != nil, "strict mode must reject two-byte trailing bits")
	decoded, err = base64.StdEncoding.DecodeString("Zm9v!mFy")
	assertBytes(decoded, "foo", "malformed decode must return partial data")
	assert(err != nil, "malformed suffix must return an error")
	if corrupt, ok := err.(base64.CorruptInputError); ok {
		assert(int(corrupt) == 4, "CorruptInputError byte offset")
	} else {
		panic("expected CorruptInputError")
	}
	appended, err := base64.StdEncoding.AppendDecode([]byte("pre"), []byte("Zm9v!"))
	assertBytes(appended, "prefoo", "AppendDecode must retain prefix and partial output")
	assert(err != nil, "AppendDecode malformed suffix")
}

func testDirectAndAppendAPIs() {
	input := []byte("direct methods")
	encoded := make([]byte, base64.StdEncoding.EncodedLen(len(input)))
	base64.StdEncoding.Encode(encoded, input)
	decoded := make([]byte, base64.StdEncoding.DecodedLen(len(encoded)))
	n, err := base64.StdEncoding.Decode(decoded, encoded)
	assert(err == nil && bytes.Equal(decoded[:n], input), "direct Encode/Decode")
	appended := base64.RawStdEncoding.AppendEncode([]byte("prefix:"), input)
	assert(strings.HasPrefix(string(appended), "prefix:"), "AppendEncode prefix")
	decodedAppend, err := base64.RawStdEncoding.AppendDecode([]byte("prefix:"), appended[len("prefix:"):])
	assert(err == nil, "AppendDecode valid input")
	assertBytes(decodedAppend, "prefix:direct methods", "append round trip")
	maxInt := int(^uint(0) >> 1)
	assert(didPanic(func() {
		_ = base64.StdEncoding.EncodedLen(maxInt)
	}), "EncodedLen overflow must panic")
}

func testStreaming() {
	input := []byte("streaming data split across awkward boundaries")
	var encoded bytes.Buffer
	w := base64.NewEncoder(base64.StdEncoding, &encoded)
	for _, chunk := range [][]byte{input[:1], input[1:3], input[3:17], input[17:]} {
		n, err := w.Write(chunk)
		assert(n == len(chunk) && err == nil, "stream encoder Write")
	}
	assert(w.Close() == nil, "stream encoder Close")
	assert(w.Close() == nil, "stream encoder Close is idempotent")
	_, err := w.Write([]byte("late"))
	assert(err != nil, "stream encoder rejects Write after Close")
	assert(encoded.String() == base64.StdEncoding.EncodeToString(input), "stream encoder output")
	r := base64.NewDecoder(base64.StdEncoding, &chunkReader{
		data: []byte("\r\n" + encoded.String() + "\n"), chunk: 1,
	})
	decoded, err := io.ReadAll(r)
	assert(err == nil && bytes.Equal(decoded, input), "stream decoder tiny chunks")
	var raw bytes.Buffer
	rawWriter := base64.NewEncoder(base64.RawStdEncoding, &raw)
	_, err = rawWriter.Write([]byte("x"))
	assert(err == nil && rawWriter.Close() == nil, "raw stream encoder")
	assert(raw.String() == "eA", "raw stream final fragment")
	short := base64.NewEncoder(base64.StdEncoding, &shortWriter{})
	_, err = short.Write([]byte("abc"))
	assert(errors.Is(err, io.ErrShortWrite), "short stream write must report ErrShortWrite")
	_, err = io.ReadAll(base64.NewDecoder(base64.StdEncoding, &invalidReader{}))
	assert(errors.Is(err, io.ErrInvalidRead), "invalid Reader count must be rejected")
	_, err = io.ReadAll(base64.NewDecoder(base64.StdEncoding, &noProgressReader{}))
	assert(errors.Is(err, io.ErrNoProgress), "non-progressing Reader must terminate")
	partial, err := io.ReadAll(base64.NewDecoder(base64.StdEncoding, &chunkReader{
		data: []byte("Zm9v!mFy"), chunk: 2,
	}))
	assertBytes(partial, "foo", "stream decoder malformed partial output")
	assert(err != nil, "stream decoder malformed error")
	partial, err = io.ReadAll(base64.NewDecoder(base64.StdEncoding, &chunkReader{
		data: []byte("Zg==AAAA"), chunk: 1,
	}))
	assertBytes(partial, "f", "stream decoder data before terminal padding")
	assert(err != nil, "stream decoder must reject data after padding across read boundaries")
	if corrupt, ok := err.(base64.CorruptInputError); ok {
		assert(int(corrupt) == 4, "stream corruption offset must span chunks")
	} else {
		panic("expected streaming CorruptInputError")
	}
}

func main() {
	testRFCVectors()
	testCustomEncoding()
	testMalformedInput()
	testDirectAndAppendAPIs()
	testStreaming()
}
