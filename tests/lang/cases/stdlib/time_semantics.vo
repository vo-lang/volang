package main

import (
	"time"
)

func main() {
	testZeroAndEpoch()
	testNormalizedUnix()
	testWideCalendarAndOverflow()
	testArithmeticAndRounding()
	testLocationConstruction()
	testStrictTextAndJSON()
	testLayoutCompleteness()
	testMonotonicState()
}

func testZeroAndEpoch() {
	var zero time.Time
	assert(zero.IsZero())
	assert(zero.Year() == 1 && zero.Month() == time.January && zero.Day() == 1)
	assert(zero.Hour() == 0 && zero.Minute() == 0 && zero.Second() == 0)
	assert(zero.Unix() == -62135596800)
	assert(zero.UnixNano() == int64(-9223372036854775807 - 1))
	name, offset := zero.Zone()
	assert(name == "UTC" && offset == 0)
	assert(zero.Location() == time.UTC)
	assert(zero.Format(time.RFC3339Nano) == "0001-01-01T00:00:00Z")
	epoch := time.Unix(0, 0)
	assert(!epoch.IsZero())
	assert(epoch.Unix() == 0 && epoch.Nanosecond() == 0)
	assert(epoch.Year() == 1970)
	assert(!epoch.Equal(zero))
	assert(epoch.Compare(zero) == 1 && zero.Compare(epoch) == -1)
	assert(zero.Compare(zero) == 0)
}

func testNormalizedUnix() {
	t := time.Unix(0, -1)
	assert(t.Unix() == -1 && t.Nanosecond() == 999999999)
	assert(t.UnixNano() == -1)
	t = time.Unix(-1, 1000000001)
	assert(t.Unix() == 0 && t.Nanosecond() == 1)
	assert(time.UnixMilli(-1).UnixMilli() == -1)
	assert(time.UnixMilli(-1).Unix() == -1)
	assert(time.UnixMilli(-1).Nanosecond() == 999000000)
	assert(time.UnixMicro(-1).UnixMicro() == -1)
	assert(time.UnixMicro(-1).Nanosecond() == 999999000)
}

func testWideCalendarAndOverflow() {
	neg := time.Date(-10000, time.January, 1, 0, 0, 0, 0, time.UTC)
	assert(neg.Year() == -10000)
	assert(neg.Format(time.DateOnly) == "-10000-01-01")
	yearMinusOne := time.Date(-1, time.January, 1, 0, 0, 0, 0, time.UTC)
	assert(yearMinusOne.Format(time.DateOnly) == "-0001-01-01")
	assert(yearMinusOne.Format("06") == "01")
	yearZero := time.Date(0, time.January, 1, 0, 0, 0, 0, time.UTC)
	assert(yearZero.Unix() == -62167219200 && yearZero.Weekday() == time.Saturday)
	wide := time.Date(10000, time.December, 31, 23, 59, 59, 999999999, time.UTC)
	assert(wide.Year() == 10000 && wide.Month() == time.December && wide.Day() == 31)
	assert(wide.Format(time.RFC3339Nano) == "10000-12-31T23:59:59.999999999Z")
	veryWide := time.Date(292277000000, time.January, 1, 0, 0, 0, 0, time.UTC)
	assert(veryWide.Year() == 292277000000)
	assert(veryWide.Unix() == 9223371197536780800)
	assert(veryWide.Format(time.DateOnly) == "292277000000-01-01")
	veryOld := time.Date(-292277000000, time.January, 1, 0, 0, 0, 0, time.UTC)
	assert(veryOld.Unix() == -9223371321871219200)
	assert(veryOld.Weekday() == time.Saturday)
	nanoMax := time.Unix(9223372036, 854775807).UTC()
	assert(nanoMax.UnixNano() == int64(9223372036854775807))
	assert(nanoMax.UnixMilli() == 9223372036854)
	assert(nanoMax.UnixMicro() == 9223372036854775)
	nanoMin := time.Unix(-9223372037, 145224192).UTC()
	assert(nanoMin.UnixNano() == int64(-9223372036854775807 - 1))
	assert(nanoMin.UnixMilli() == -9223372036855)
	assert(nanoMin.UnixMicro() == -9223372036854776)
	max := time.Unix(int64(9223372036854775807), 2000000000)
	assert(max.Unix() == int64(9223372036854775807))
	assert(max.Nanosecond() == 999999999)
	assert(max.UnixNano() == int64(9223372036854775807))
	min := time.Unix(int64(-9223372036854775807 - 1), -1)
	assert(min.Unix() == int64(-9223372036854775807 - 1))
	assert(min.Nanosecond() == 0)
	assert(min.UnixNano() == int64(-9223372036854775807 - 1))
	assert(max.Add(time.Nanosecond).Equal(max))
	assert(min.Add(-time.Nanosecond).Equal(min))
	assert(max.Sub(min) == time.Duration(9223372036854775807))
	assert(min.Sub(max) == time.Duration(-9223372036854775807 - 1))
	maxUTC := time.Unix(int64(9223372036854775807), 0).UTC()
	maxLocal := maxUTC.In(time.FixedZone("NEXT", 24 * 3600))
	maxHour, maxMinute, maxSecond := maxUTC.Clock()
	localHour, localMinute, localSecond := maxLocal.Clock()
	assert(localHour == maxHour && localMinute == maxMinute && localSecond == maxSecond)
	assert(int(maxLocal.Weekday()) == (int(maxUTC.Weekday()) + 1) % 7)
	minUTC := time.Unix(int64(-9223372036854775807 - 1), 0).UTC()
	minLocal := minUTC.In(time.FixedZone("PREV", -24 * 3600))
	assert(int(minLocal.Weekday()) == (int(minUTC.Weekday()) + 6) % 7)
}

func testArithmeticAndRounding() {
	assert(time.Tick(0) == nil)
	greekMicro, greekMicroErr := time.ParseDuration("1μs")
	assert(greekMicroErr == nil && greekMicro == time.Microsecond)
	assert((1500 * time.Millisecond).Seconds() == 1.5)
	assert((90 * time.Second).Minutes() == 1.5)
	assert((90 * time.Minute).Hours() == 1.5)
	assert((1500 * time.Millisecond).Truncate(time.Second) == time.Second)
	assert((1500 * time.Millisecond).Round(time.Second) == 2 * time.Second)
	assert((-1500 * time.Millisecond).Round(time.Second) == -2 * time.Second)
	assert(time.Duration(-9223372036854775807 - 1).Abs() == time.Duration(9223372036854775807))
	var zero time.Time
	assert(zero.Add(-2500 * time.Millisecond).Truncate(time.Second).Sub(zero) == -3 * time.Second)
	assert(zero.Add(-2500 * time.Millisecond).Round(time.Second).Sub(zero) == -2 * time.Second)
	assert(zero.Add(-500 * time.Millisecond).Round(time.Second).Equal(zero))
	assert(zero.Add(500 * time.Millisecond).Round(time.Second).Sub(zero) == time.Second)
	assert(zero.Add(1500 * time.Millisecond).Round(time.Second).Sub(zero) == 2 * time.Second)
	t := time.Unix(-2, 500000000).UTC()
	assert(t.Truncate(time.Second).Unix() == -2)
	assert(t.Round(time.Second).Unix() == -1)
	assert(t.Round(time.Second).Nanosecond() == 0)
	assert(!t.Truncate(time.Second).HasMonotonic())
	assert(!t.Round(0).HasMonotonic())
	leap := time.Date(2024, time.February, 29, 12, 0, 0, 0, time.UTC)
	next := leap.AddDate(1, 0, 0)
	assert(next.Year() == 2025 && next.Month() == time.March && next.Day() == 1)
}

func testLocationConstruction() {
	empty, emptyErr := time.LoadLocation("")
	assert(emptyErr == nil && empty == time.UTC)
	assert(time.UTC.String() == "UTC" && time.Local.String() == "Local")
	ist := time.FixedZone("IST", 5 * 3600 + 30 * 60)
	localEpoch := time.Date(1970, time.January, 1, 5, 30, 0, 0, ist)
	assert(localEpoch.Unix() == 0)
	name, offset := localEpoch.Zone()
	assert(name == "IST" && offset == 19800)
	ny, err := time.LoadLocation("America/New_York")
	assert(err == nil)
	summer := time.Date(2025, time.June, 15, 12, 0, 0, 0, ny)
	winter := time.Date(2025, time.January, 15, 12, 0, 0, 0, ny)
	_, summerOffset := summer.Zone()
	_, winterOffset := winter.Zone()
	assert(summer.Unix() == 1750003200 && summerOffset == -14400)
	assert(winter.Unix() == 1736960400 && winterOffset == -18000)
	parsedNY, parsedNYErr := time.ParseInLocation(time.DateTime, "2025-06-15 12:00:00", ny)
	assert(parsedNYErr == nil && parsedNY.Unix() == summer.Unix())
	gap := time.Date(2025, time.March, 9, 2, 30, 0, 0, ny)
	assert(gap.Unix() == 1741501800)
	fold := time.Date(2025, time.November, 2, 1, 30, 0, 0, ny)
	assert(fold.Unix() == 1762061400)
}

func testStrictTextAndJSON() {
	t, err := time.Parse(time.RFC3339, "2024-03-15T14:30:45.1234567899Z")
	assert(err == nil && t.Nanosecond() == 123456789)
	assert(t.Format("15:04:05,999999999") == "14:30:45,123456789")
	t24, err24 := time.Parse(time.RFC3339, "2024-03-15T14:30:45+24:59")
	assert(err24 == nil)
	_, offset := t24.Zone()
	assert(offset == 24 * 3600 + 59 * 60)
	_, marshalErr := t24.MarshalJSON()
	assert(marshalErr != nil)
	gmt, gmtErr := time.Parse("2006-01-02 15:04:05 MST", "2024-01-01 00:00:00 GMT+3")
	assert(gmtErr == nil && gmt.Unix() == 1704067200)
	gmtName, gmtOffset := gmt.Zone()
	assert(gmtName == "GMT+3" && gmtOffset == 10800)
	_, shortZoneErr := time.Parse("2006-01-02 15:04:05 MST", "2024-01-01 00:00:00 A")
	assert(shortZoneErr != nil)
	var zero time.Time
	json, jsonErr := zero.MarshalJSON()
	assert(jsonErr == nil && string(json) == "\"0001-01-01T00:00:00Z\"")
	text, textErr := zero.MarshalText()
	assert(textErr == nil && string(text) == "0001-01-01T00:00:00Z")
	wide := time.Date(10000, time.January, 1, 0, 0, 0, 0, time.UTC)
	_, wideJSONErr := wide.MarshalJSON()
	_, wideTextErr := wide.MarshalText()
	assert(wideJSONErr != nil && wideTextErr != nil)
	keep := time.Unix(123, 0)
	assert(keep.UnmarshalJSON([]byte("null")) == nil)
	assert(keep.Unix() == 123)
	assert(keep.UnmarshalJSON([]byte("123")) != nil)
}

func testLayoutCompleteness() {
	leap := time.Date(2024, time.February, 29, 15, 4, 5, 0, time.UTC)
	assert(leap.Format("__2 002") == " 60 060")
	assert(leap.Format("Month Janx _2006") == "Month Janx _2024")
	shortHour, shortHourErr := time.Parse("15", "3")
	assert(shortHourErr == nil && shortHour.Hour() == 3)
	_, shortAsLongMonthErr := time.Parse("January", "Jan")
	_, longAsShortMonthErr := time.Parse("Jan", "January")
	_, shortAsLongWeekdayErr := time.Parse("Monday", "Mon")
	_, wrongMeridiemCaseErr := time.Parse("PM", "pm")
	assert(shortAsLongMonthErr != nil && longAsShortMonthErr != nil)
	assert(shortAsLongWeekdayErr != nil && wrongMeridiemCaseErr != nil)
	yday, ydayErr := time.Parse("2006-002", "2024-060")
	assert(ydayErr == nil)
	assert(yday.Month() == time.February && yday.Day() == 29)
	_, ydayRangeErr := time.Parse("2006-002", "2023-366")
	assert(ydayRangeErr != nil)
	_, ydayConflictErr := time.Parse("2006-01-02 002", "2024-03-01 060")
	assert(ydayConflictErr != nil)
	pmFirst, pmFirstErr := time.Parse("PM 3", "PM 3")
	assert(pmFirstErr == nil && pmFirst.Hour() == 15)
	secondZone := time.FixedZone("SEC", 1 * 3600 + 2 * 60 + 3)
	zoned := time.Date(2024, time.January, 2, 3, 4, 5, 0, secondZone)
	assert(zoned.Format("-070000 -07:00:00 Z070000 Z07:00:00 Z07") ==
		"+010203 +01:02:03 +010203 +01:02:03 +01")
	parsed, parseErr := time.Parse("2006-01-02 -07:00:00", "2024-01-02 +01:02:03")
	assert(parseErr == nil)
	_, parsedOffset := parsed.Zone()
	assert(parsedOffset == 3723)
	assert(parsed.Format("MST") == "+0102")
	utc := time.Date(2024, time.January, 1, 0, 0, 0, 0, time.UTC)
	assert(utc.Format("Z070000 Z07:00:00 Z07") == "Z Z Z")
}

func testMonotonicState() {
	now := time.Now()
	assert(now.HasMonotonic())
	assert(now.Add(time.Nanosecond).HasMonotonic())
	assert(!now.UTC().HasMonotonic())
	assert(!now.Local().HasMonotonic())
	assert(!now.In(time.UTC).HasMonotonic())
	assert(!now.Round(time.Second).HasMonotonic())
	assert(!now.Truncate(time.Second).HasMonotonic())
}
