package main

import (
	"bytes"
)

func main() {
	titled := bytes.ToTitle([]byte("Hello, gophers"))
	assert(string(titled) == "HELLO, GOPHERS", "bytes.ToTitle should title-case every letter")
	assert(string(bytes.ToUpper([]byte("Straße"))) == "STRAßE", "bytes.ToUpper should use single-rune Unicode mappings")
	assert(string(bytes.ToLower([]byte("İ"))) == "i", "bytes.ToLower should use single-rune Unicode mappings")
	assert(string(bytes.ToTitle([]byte("ǆ"))) == "ǅ", "bytes.ToTitle should preserve distinct titlecase mappings")
	assert(bytes.EqualFold([]byte("MiXeD"), []byte("mixed")), "bytes.EqualFold should ignore case")
	assert(bytes.EqualFold([]byte("Σ"), []byte("ς")), "bytes.EqualFold should follow the complete simple-fold orbit")
	assert(bytes.EqualFold([]byte("K"), []byte("K")), "bytes.EqualFold should include Unicode compatibility folds")
	assert(bytes.EqualFold([]byte{0xff}, []byte{0xfe}), "bytes.EqualFold should decode malformed bytes as RuneError")
	assert(!bytes.EqualFold([]byte("ß"), []byte("ss")), "bytes.EqualFold should not apply multi-rune full folding")
	assert(!bytes.EqualFold([]byte("mixed"), []byte("mismatch")), "bytes.EqualFold should reject different bytes")
}
