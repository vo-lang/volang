// Test dyn_set_attr with interface field type mismatch
// Bug: when assigning to interface field, should check if value implements the interface
package main

import (
	"dyn"
	"fmt"
)

type Reader interface {
	Read() string
}

type Writer interface {
	Write(s string)
}

type Container struct {
	R Reader // interface field
}

type MyWriter struct {
	data string `dyn:"data"`
}

func (w *MyWriter) Write(s string) {
	w.data = s
}

// MyWriter implements Writer but NOT Reader
func testSetMismatch() bool {
	c := &Container{}
	var obj any = c
	w := &MyWriter{}
	// MyWriter does not satisfy Reader, so SetAttr returns an error.
	// MyWriter doesn't implement Reader (no Read method)
	return dyn.SetAttr(obj, "R", w) != nil
}

func main() {
	rejected := testSetMismatch()
	assert(rejected, "interface mismatch should return an error")
	fmt.Println("Got expected error")
	fmt.Println("PASS")
}
// Expected: error when assigning MyWriter to Reader field
