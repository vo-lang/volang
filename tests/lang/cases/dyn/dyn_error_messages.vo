// Test: Error messages propagated by dynamic access and the ? operator.
package main

import (
	"errors"
	"fmt"
	"strings"
)

type User struct {
	name string `dyn:"name"`
	age int `dyn:"age"`
}

func (u *User) GetName() string {
	return u.name
}

func failWithMessage() error {
	return errors.New("custom error: operation failed")
}

func failWithWrapped() error {
	inner := errors.New("inner error")
	return errors.Wrap(inner, "outer context")
}

func testQuestionError() error {
	failWithMessage()?
	return nil
}

func testQuestionWrapped() error {
	failWithWrapped()?
	return nil
}

func testDynNilAccess() error {
	var obj any = nil
	_ = obj~>field?
	return nil
}

func testDynNilMethodCall() error {
	var obj any = nil
	_ = obj~>Method()?
	return nil
}

func testDynNilIndex() error {
	var obj any = nil
	_ = obj~>[0]?
	return nil
}

func testDynFieldNotFound() error {
	var obj any = &User{name: "test", age: 30}
	_ = obj~>nonexistent?
	return nil
}

func testDynMethodNotFound() error {
	var obj any = &User{name: "test", age: 30}
	_ = obj~>NonexistentMethod()?
	return nil
}

func main() error {
	err := testQuestionError()
	msg := fmt.Sprint(err)
	fmt.Println("Test 1 - ? error message:", msg)
	assert(strings.Contains(msg, "custom error"), "should contain 'custom error'")
	assert(strings.Contains(msg, "operation failed"), "should contain 'operation failed'")
	err = testQuestionWrapped()
	msg = fmt.Sprint(err)
	fmt.Println("Test 2 - wrapped error:", msg)
	assert(strings.Contains(msg, "outer context"), "should contain 'outer context'")
	assert(strings.Contains(msg, "inner error"), "should contain 'inner error'")
	err = testDynNilAccess()
	msg = fmt.Sprint(err)
	fmt.Println("Test 3 - nil access error:", msg)
	assert(msg != "", "should have an error message for nil access")
	assert(strings.Contains(msg, "nil") || strings.Contains(msg, "Nil"), "should mention nil")
	err = testDynNilMethodCall()
	msg = fmt.Sprint(err)
	fmt.Println("Test 4 - nil method call error:", msg)
	assert(msg != "", "should have an error message for nil method call")
	err = testDynNilIndex()
	msg = fmt.Sprint(err)
	fmt.Println("Test 5 - nil index error:", msg)
	assert(msg != "", "should have an error message for nil index")
	err = testDynFieldNotFound()
	msg = fmt.Sprint(err)
	fmt.Println("Test 6 - field not found error:", msg)
	assert(msg != "", "should have an error message for field not found")
	assert(strings.Contains(msg, "nonexistent") || strings.Contains(msg, "field"), "should mention field name or 'field'")
	err = testDynMethodNotFound()
	msg = fmt.Sprint(err)
	fmt.Println("Test 7 - method not found error:", msg)
	assert(msg != "", "should have an error message for method not found")
	_, err = testDynErrorReturn()
	fmt.Println("Test 8 - error without ?:", err)
	assert(err != nil, "should return error")
	fmt.Println("dyn_error_messages: ALL PASSED")
	return nil
}

func testDynErrorReturn() (any, error) {
	var obj any = nil
	return obj~>field
}
