// Test: Protocol methods on MapObject and embedded types
// Verifies that ~> operator works with dyn.MapObject directly and via embedding.
package main

import (
	"fmt"
	"dyn"
)

type Config struct {
	dyn.MapObject
}

func main() {
	err := testMapObject()
	if err != nil {
		panic(err.Error())
	}
	err = testEmbedded()
	if err != nil {
		panic(err.Error())
	}
	fmt.Println("ok")
}

func testMapObject() error {
	// Test with MapObject directly
	a := make(dyn.MapObject)
	assert(dyn.SetAttr(a, "name", "hello") == nil)
	assert(dyn.SetAttr(a, "count", 42) == nil)
	// Read back
	name := a~>name?
	if name.(string) != "hello" {
		panic("name mismatch")
	}
	count := a~>count?
	if count.(int) != 42 {
		panic("count mismatch")
	}
	// Index access
	assert(dyn.SetIndex(a, "key1", "value1") == nil)
	v := a~>["key1"]?
	if v.(string) != "value1" {
		panic("key1 mismatch")
	}
	return nil
}

func testEmbedded() error {
	// Test with Config embedding MapObject
	a := Config{make(dyn.MapObject)}
	assert(dyn.SetAttr(a, "field1", "hello") == nil)
	assert(dyn.SetAttr(a, "field2", 123) == nil)
	// Read back
	v1 := a~>field1?
	if v1.(string) != "hello" {
		panic("field1 mismatch")
	}
	v2 := a~>field2?
	if v2.(int) != 123 {
		panic("field2 mismatch")
	}
	return nil
}
