package main

import (
	"dyn"
	"fmt"
)

type MyError struct {
	msg string `dyn:"msg"`
}

func (e MyError) Error() string {
	return e.msg
}

func (e MyError) Code() int {
	return 0
}

func (e MyError) Unwrap() error {
	return nil
}

func (e MyError) Data() any {
	return nil
}

func newError(msg string) error {
	return MyError{msg: msg}
}

type S struct {
	x int `dyn:"x"`
}

func testSetField() error {
	s := &S{x: 1}
	var a any = s
	assert(dyn.SetAttr(a, "x", 42) == nil)
	if s.x != 42 {
		return newError("field not set")
	}
	return nil
}

func testSetMap() error {
	m := map[string]int{}
	var a any = m
	assert(dyn.SetIndex(a, "k", 7) == nil)
	if m["k"] != 7 {
		return newError("map not set")
	}
	return nil
}

func testSetSlice() error {
	s := []int{1, 2, 3}
	var a any = s
	assert(dyn.SetIndex(a, 1, 10) == nil)
	if s[1] != 10 {
		return newError("slice not set")
	}
	return nil
}

func testSetStringReturnsError() bool {
	var a any = "abc"
	return dyn.SetIndex(a, 0, byte(1)) != nil
}

func testSetArrayReturnsError() bool {
	arr := [3]int{1, 2, 3}
	var a any = arr
	return dyn.SetIndex(a, 0, 9) != nil
}

func main() int {
	err := testSetField()
	assert(err == nil, "field set should succeed")
	err = testSetMap()
	assert(err == nil, "map set should succeed")
	err = testSetSlice()
	assert(err == nil, "slice set should succeed")
	assert(testSetStringReturnsError(), "string index set should return an error")
	assert(testSetArrayReturnsError(), "array index set should return an error")
	fmt.Println("done")
	return 0
}
