package main

import (
	"fmt"
	"strings"
)

func parseLikeRunner(mode string, args []string) string {
	assert(mode == "both", "mode mismatch")
	verbose := false
	singleFile := ""
	for i := 0; i < len(args); i++ {
		arg := args[i]
		if arg == "-v" || arg == "--verbose" {
			verbose = true
		} else if strings.HasPrefix(arg, "--color=") {
			continue
		} else if !strings.HasPrefix(arg, "-") {
			singleFile = arg
		}
	}
	assert(verbose, "verbose should be true")
	assert(singleFile == "tests/lang/cases/runtime/control_flow/multi_return_as_arg.vo", "singleFile mismatch")
	assert(strings.HasPrefix(singleFile, "tests/lang/cases/"), "singleFile prefix mismatch")
	return singleFile
}

func main() {
	args := []string{"-v", "tests/lang/cases/runtime/control_flow/multi_return_as_arg.vo"}
	file := parseLikeRunner("both", args)
	assert(file == "tests/lang/cases/runtime/control_flow/multi_return_as_arg.vo", "returned file mismatch")
	fmt.Println("static_call_string_slice_args: ok")
}
