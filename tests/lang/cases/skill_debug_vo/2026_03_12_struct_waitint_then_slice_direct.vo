package main

import "time"

type Pair struct {
	Left port int
	Right port int
}

func waitBool(ch port bool, label string) bool {
	done := false
	value := false
	for i := 0; i < 100 && !done; i += 1 {
		select {
		case value = <-ch:
			done = true
		default:
			time.Sleep(5 * time.Millisecond)
		}
	}
	assert(done, label)
	return value
}

func waitInt(ch port int, label string) int {
	done := false
	value := 0
	for i := 0; i < 100 && !done; i += 1 {
		select {
		case value = <-ch:
			done = true
		default:
			time.Sleep(5 * time.Millisecond)
		}
	}
	assert(done, label)
	return value
}

func main() {
	{
		i := make(island)
		outer := make(port Pair, 1)
		inner := make(port int, 1)
		eq := make(port bool, 1)
		go @(i) func(ch port Pair, out port bool) {
			pair := <-ch
			out <- (pair.Left == pair.Right)
			pair.Left <- 101
		}(outer, eq)
		outer <- Pair{Left: inner, Right: inner}
		assert(waitBool(eq, "struct eq") == true, "struct eq true")
		assert(waitInt(inner, "struct inner") == 101, "struct inner 101")
	}

	{
		i := make(island)
		outer := make(port []port int, 1)
		inner := make(port int, 1)
		eq := make(port bool, 1)
		go @(i) func(ch port []port int, out port bool) {
			items := <-ch
			out <- (items[0] == items[1])
		}(outer, eq)
		outer <- []port int{inner, inner}
		assert(<-eq, "slice eq")
	}
}
