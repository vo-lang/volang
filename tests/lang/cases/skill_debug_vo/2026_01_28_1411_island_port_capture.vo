// Test port as captured variable (not argument)
package main

import (
	"time"
)

func main() {
	i := make(island)
	p := make(port int, 1)
	var send port<- int = p
	// Capture the attenuated send capability; the owner port stays on main.
	go @(i) func() {
		send <- 42
	}()
	time.Sleep(50 * time.Millisecond)
	result := <-p
	assert(result == 42, "expected 42")
	close(p)
	println("PASS")
}
