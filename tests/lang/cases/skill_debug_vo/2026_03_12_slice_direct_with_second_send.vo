package main

func main() {
	i := make(island)
	outer := make(port []port int, 1)
	inner := make(port int, 1)
	eq := make(port bool, 1)

	go @(i) func(ch port []port int, out port bool) {
		items := <-ch
		out <- (items[0] == items[1])
		items[1] <- 202
	}(outer, eq)

	outer <- []port int{inner, inner}
	assert(<-eq, "slice eq")
	assert(<-inner == 202, "slice inner")
}
