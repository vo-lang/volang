{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "outDir": "node_modules/.cache/studio-tsc/node",
    "tsBuildInfoFile": "node_modules/.cache/studio-tsc/node/tsconfig.node.tsbuildinfo",
    "strict": true
  },
  "include": ["vite.config.ts", "svelte.config.ts", "ambient.d.ts"]
}
