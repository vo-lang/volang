package main

import "time"

func waitBool(ch chan bool, label string) bool {
	done := false
	value := false
	for i := 0; i < 100 && !done; i += 1 {
		select {
		case value = <-ch:
			done = true
		default:
			time.Sleep(5 * time.Millisecond)
		}
	}
	assert(done, label)
	return value
}

func main() {
	i := make(island)
	outer := make(chan []chan int, 1)
	inner := make(chan int, 1)
	eq := make(chan bool, 1)

	go @(i) func(ch chan []chan int, out chan bool) {
		items := <-ch
		out <- (items[0] == items[1])
	}(outer, eq)

	outer <- []chan int{inner, inner}
	assert(waitBool(eq, "timed out waiting for slice nested channel alias result"), "slice nested channel aliases must preserve identity")
}
