package main

import "time"

type Pair struct {
	Left port int
	Right port int
}

func main() {
	testStruct()
	testSlice()
}

func waitBool(ch port bool, label string) bool {
	done := false
	value := false
	for i := 0; i < 100 && !done; i += 1 {
		select {
		case value = <-ch:
			done = true
		default:
			time.Sleep(5 * time.Millisecond)
		}
	}
	assert(done, label)
	return value
}

func waitInt(ch port int, label string) int {
	done := false
	value := 0
	for i := 0; i < 100 && !done; i += 1 {
		select {
		case value = <-ch:
			done = true
		default:
			time.Sleep(5 * time.Millisecond)
		}
	}
	assert(done, label)
	return value
}

func testStruct() {
	i := make(island)
	outer := make(port Pair, 1)
	inner := make(port int, 1)
	eq := make(port bool, 1)

	go @(i) func(ch port Pair, out port bool) {
		pair := <-ch
		out <- (pair.Left == pair.Right)
		pair.Left <- 101
	}(outer, eq)

	outer <- Pair{Left: inner, Right: inner}
	assert(waitBool(eq, "timed out waiting for struct nested channel alias result"), "struct nested channel aliases must preserve identity")
	assert(waitInt(inner, "timed out waiting for struct nested channel send") == 101, "struct nested channel send must work")
}

func testSlice() {
	i := make(island)
	outer := make(port []port int, 1)
	inner := make(port int, 1)
	eq := make(port bool, 1)

	go @(i) func(ch port []port int, out port bool) {
		items := <-ch
		out <- (items[0] == items[1])
		items[1] <- 202
	}(outer, eq)

	outer <- []port int{inner, inner}
	assert(<-eq, "slice nested channel aliases must preserve identity")
	assert(waitInt(inner, "timed out waiting for slice nested channel send") == 202, "slice nested channel send must work")
}
