// Minimal test for zero-value embedded field method
package main


import "fmt"
type Inner struct {
    value int
}

func (i Inner) GetValue() int {
    return i.value
}

func (i *Inner) SetValue(v int) {
    i.value = v
}

type Outer struct {
    Inner
    name string
}

type OffsetOuter struct {
    pad int
    Inner
}

func main() {
    // Test 1: Zero value Outer, call embedded method
    var o1 Outer
    v := o1.GetValue()  // value receiver on zero Inner
    assert(v == 0, "zero Inner.GetValue should be 0")
    fmt.Println("test 1 ok")
    
    // Test 2: Set via embedded pointer receiver
    var o2 Outer
    o2.SetValue(42)
    assert(o2.GetValue() == 42, "after SetValue")
    fmt.Println("test 2 ok")

    o3 := &OffsetOuter{pad: 9, Inner: Inner{value: 33}}
    get3 := o3.GetValue
    o3.Inner.value = 88
    assert(get3() == 88, "embedded value receiver method value through pointer should see mutation")

    set3 := o3.SetValue
    set3(55)
    assert(o3.Inner.value == 55, "embedded pointer receiver method value should target embedded field")

    o4 := OffsetOuter{pad: 7, Inner: Inner{value: 22}}
    get4 := o4.GetValue
    o4.Inner.value = 99
    assert(get4() == 22, "embedded value receiver method value on value should capture copied field")
    
    fmt.Println("done")
}
