# will have compiled files and executables
debug/
target/
3rdparty/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Build artifacts
*.o
*.a
*.so
*.dylib
*.rmeta
/main.vob

# Local red-team/source-contract probe build outputs
/vo_*_probe
/vo_scheduler_*
/vo_macro_hardcoded_raw_wake

# Test and coverage
*.profraw
*.profdata
tarpaulin-report.html
*.goxc
/.windsurf
/.ref
benchmarks/results/
benchmarks/**/go_bench
benchmarks/**/c_bench
benchmarks/**/*.class
benchmarks/**/luac.out
**/.vo-cache/
.volang/

