		Course{Id: 3, Name: "人物篇", Icon: "👨", Chars: []Character{
			Character{"人", "rén", "Person", "大人,好人,人们", "他是好人。", "村庄里住着很多村民。"},
			Character{"口", "kǒu", "Mouth", "门口,出口,人口", "张开口说话。", "山洞的入口在哪里？"},
			Character{"手", "shǒu", "Hand", "小手,左手,右手", "洗洗手。", "空手也能挖木头！"},
			Character{"足", "zú", "Foot", "双足,足球", "脚印在地上。", "穿上靴子跑得更快。"},
			Character{"目", "mù", "Eye", "目光,眼目", "睁开眼睛看。", "末影人不喜欢被盯着看。"},
			Character{"耳", "ěr", "Ear", "耳朵,耳机", "用耳朵听声音。", "听到僵尸的声音了！"},
		}},
		Course{Id: 4, Name: "动作篇", Icon: "🏃", Chars: []Character{
			Character{"走", "zǒu", "Walk", "走路,走开", "我们走吧。", "走路太慢了，要跑！"},
			Character{"跑", "pǎo", "Run", "跑步,快跑", "快跑！", "被苦力怕追着跑！"},
			Character{"飞", "fēi", "Fly", "飞机,飞鸟", "鸟在天上飞。", "用鞘翅可以飞翔！"},
			Character{"吃", "chī", "Eat", "吃饭,吃东西", "我想吃苹果。", "吃金苹果回血！"},
			Character{"看", "kàn", "Look", "看见,看书", "看那边！", "看地图找宝藏。"},
			Character{"打", "dǎ", "Hit", "打球,打人", "不要打人。", "打败末影龙！"},
			Character{"做", "zuò", "Make/Do", "做饭,做事", "我在做作业。", "用工作台做工具。"},
			Character{"找", "zhǎo", "Find", "找到,寻找", "我在找钥匙。", "找到隐藏的宝箱！"},
		}},
	}
}

// ============ App Entry ============

func main() {
	vogui.SetGlobalKeyHandler(handleKey)
	vogui.Run(vogui.App{
		Init: initApp,
		View: view,
	})
}

func initApp() any {
	courses := loadCourses()
	learned := make([]bool, 50) // Track up to 50 chars
	return &State{
		Page:          "home",
		CurrentCourse: 0,
		CurrentChar:   0,
		ShowDetail:    false,
		Learned:       learned,
		Courses:       courses,
		TotalLearned:  0,
	}
}

// ============ Update Logic ============

func handleKey(state any, key string) {
	s := state.(*State)
	if s.Page == "lesson" {
		if key == "ArrowLeft" {
			actionPrevChar(s)
		} else if key == "ArrowRight" {
			actionNextChar(s)
		} else if key == " " || key == "Enter" {
			actionToggleDetail(s)
		} else if key == "Escape" {
			actionGoHome(s)
		}
	}
}

func actionSelectCourse(s *State, idx int) {
	s.CurrentCourse = idx
	s.CurrentChar = 0
	s.ShowDetail = false
	s.Page = "lesson"
}

func actionGoHome(s *State) {
	s.Page = "home"
}

func actionNextChar(s *State) {
	course := s.Courses[s.CurrentCourse]
	// Mark current as learned
	charIdx := getGlobalCharIndex(s)
	if charIdx < len(s.Learned) && !s.Learned[charIdx] {
		s.Learned[charIdx] = true
		s.TotalLearned++
	}
	if s.CurrentChar < len(course.Chars)-1 {
		s.CurrentChar++
		s.ShowDetail = false
	} else {
		s.Page = "complete"
	}
}

func actionPrevChar(s *State) {
	if s.CurrentChar > 0 {
		s.CurrentChar--
		s.ShowDetail = false
	}
}

func actionToggleDetail(s *State) {
	s.ShowDetail = !s.ShowDetail
}

func actionContinue(s *State) {
	s.Page = "home"
}

func getGlobalCharIndex(s *State) int {
	idx := 0
	for i := 0; i < s.CurrentCourse; i++ {
		idx += len(s.Courses[i].Chars)
	}
	return idx + s.CurrentChar
}

func getTotalChars(s *State) int {
	total := 0
	for _, c := range s.Courses {
		total += len(c.Chars)
	}
	return total
}

// ============ View ============

func view(state any) vogui.Node {
	s := state.(*State)
	if s.Page == "home" {
		return viewHome(s)
	}
	if s.Page == "complete" {
		return viewComplete(s)
	}
	return viewLesson(s)
}

func viewHome(s *State) vogui.Node {
	total := getTotalChars(s)
	progress := 0
	if total > 0 {
		progress = s.TotalLearned * 100 / total
	}

	var courseNodes []vogui.Node
	for i, c := range s.Courses {
		idx := i
		courseNodes = append(courseNodes,
			vogui.Button(fmt.Sprintf("%s %s (%d字)", c.Icon, c.Name, len(c.Chars)), vogui.OnInt(actionSelectCourse, idx)).
				Bg(ColorGreen).
				Fg("#fff").
				Rounded(10).
				M(5).
				P(15).
				Border("3px solid "+ColorBrown),
		)
	}

	return vogui.Center(
		vogui.Column(
			// Title
			vogui.Row(
				vogui.Text("🎮 识字").Font(28).Bold().Fg(ColorGreen),
				vogui.Text("冒险").Font(28).Bold().Fg(ColorBrown),
			).M(15),

			// Progress
			vogui.Column(
				vogui.Text(fmt.Sprintf("已学习: %d / %d 字", s.TotalLearned, total)).Font(14).Fg(ColorText),
				vogui.Row(
					vogui.Div().W(progress*2).H(8).Bg(ColorGreen).Rounded(4),
					vogui.Div().W((100-progress)*2).H(8).Bg("#ddd").Rounded(4),
				).Gap(0),
			).M(10).P(10).Bg("#fff").Rounded(8).Border("2px solid "+ColorBorder),

			// Course List
			vogui.Text("选择课程:").Font(16).Bold().Fg(ColorText).M(10),
			vogui.Column(courseNodes...).Gap(5),

			// Footer
			vogui.Text("← → 方向键导航 | Space 显示详情").Font(11).Fg("#999").M(15),
		).Bg(ColorBg).P(15).Gap(5).W(300),
	)
}

func viewLesson(s *State) vogui.Node {
	course := s.Courses[s.CurrentCourse]
	char := course.Chars[s.CurrentChar]

	return vogui.Column(
		// Navbar
		vogui.Row(
			vogui.Button("← 返回", vogui.OnClick(actionGoHome)).
				Bg(ColorRed).Fg("#fff").Rounded(8).P(8),
			vogui.Spacer(),
			vogui.Text(fmt.Sprintf("%s %s  %d/%d", course.Icon, course.Name, s.CurrentChar+1, len(course.Chars))).
				Font(14).Fg(ColorText).Bold(),
			vogui.Spacer(),
		).P(8).Bg(ColorBg).Border("0 0 2px 0 solid "+ColorBorder),

		// Main Content
		vogui.Center(
			vogui.Column(
				// Pinyin (Conditional)
				vogui.Show(s.ShowDetail,
					vogui.Text(char.Pinyin).Font(32).Fg(ColorPurple).Bold().M(5),
				),

				// Hanzi Card
				vogui.Button(char.Char, vogui.OnClick(actionToggleDetail)).
					Font(90).
					Fg(ColorRed).
					Bg("#fff").
					W(160).H(160).
					Border("4px dashed "+ColorBorder).
					Rounded(10),

				// Hint
				vogui.Show(!s.ShowDetail,
					vogui.Text("👆 点击查看详情").Font(12).Fg("#999").M(8),
				),

				// Details
				vogui.Show(s.ShowDetail,
					vogui.Column(
						vogui.Row(
							vogui.Text("📖 释义: ").Bold().Fg(ColorBrown),
							vogui.Text(char.Meaning).Fg(ColorText),
						),
						vogui.Row(
							vogui.Text("📝 组词: ").Bold().Fg(ColorBrown),
							vogui.Text(char.Words).Fg(ColorText),
						),
						vogui.Row(
							vogui.Text("💬 例句: ").Bold().Fg(ColorBrown),
							vogui.Text(char.Example).Fg(ColorText),
						),
					).P(12).Bg("#fff").Rounded(8).Border("2px solid "+ColorBorder).M(8).Gap(8),
				),

				// Minecraft Sentence
				vogui.Column(
					vogui.Text("⛏️ Minecraft 造句").Bold().Fg(ColorYellow),
					vogui.Text(char.McSentence).Fg("#fff").Font(14),
				).P(12).M(5).Bg("#2d2d2d").Rounded(8).Border("3px solid "+ColorBrown),
			).Gap(5),
		).Flex(1),

		// Navigation
		vogui.Row(
			vogui.If(s.CurrentChar > 0,
				vogui.Button("◀ 上一个", vogui.OnClick(actionPrevChar)).
					Bg(ColorBlue).Fg("#fff").Rounded(20).P(10),
			),
			vogui.Spacer(),
			vogui.Button("下一个 ▶", vogui.OnClick(actionNextChar)).
				Bg(ColorGreen).Fg("#fff").Rounded(20).P(10),
		).P(15),
	).Bg(ColorBg).W(300)
}

func viewComplete(s *State) vogui.Node {
	course := s.Courses[s.CurrentCourse]
	return vogui.Center(
		vogui.Column(
			vogui.Text("🎉").Font(60),
			vogui.Text("太棒了！").Font(28).Bold().Fg(ColorGreen),
			vogui.Text(fmt.Sprintf("你完成了 %s！", course.Name)).Font(16).Fg(ColorText),
			vogui.Text(fmt.Sprintf("学习了 %d 个汉字", len(course.Chars))).Font(14).Fg(ColorText).M(10),
			vogui.Button("继续学习", vogui.OnClick(actionContinue)).
				Bg(ColorGreen).Fg("#fff").Rounded(10).P(15).M(20),
		).Bg(ColorBg).P(30).Rounded(15).Border("4px solid "+ColorBorder).Gap(10).W(300),
	)
}
