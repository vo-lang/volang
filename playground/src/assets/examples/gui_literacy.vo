// 识字冒险 (Literacy Adventure)
// A Chinese literacy app for kids with Minecraft theme.
// Features: Multiple levels, progress tracking, flashcards with pinyin/meaning/examples.

package main

import "vogui"
import "fmt"

// ============ Theme Colors ============

const ColorGreen = "#4ade80"   // Grass green - success, primary
const ColorBrown = "#8b5a2b"   // Dirt brown - borders
const ColorBlue = "#60a5fa"    // Sky blue - secondary
const ColorYellow = "#ffd700"  // Gold - highlights
const ColorRed = "#ee5544"     // Redstone - hanzi, danger
const ColorPurple = "#a855f7"  // Amethyst - special
const ColorBg = "#f5f0e6"      // Beige paper
const ColorBorder = "#d4a574"  // Paper border
const ColorText = "#5a4a42"    // Dark brown text

// ============ Data Types ============

type Character struct {
	Char       string
	Pinyin     string
	Meaning    string
	Words      string   // Comma-separated
	Example    string
	McSentence string
}

type Course struct {
	Id    int
	Name  string
	Icon  string
	Chars []Character
}

type State struct {
	Page          string // "home", "lesson", "complete"
	CurrentCourse int
	CurrentChar   int
	ShowDetail    bool
	Learned       []bool // Track learned characters per course
	Courses       []Course
	TotalLearned  int
}

// ============ Character Data (JSON-style) ============

func loadCourses() []Course {
	return []Course{
		Course{Id: 0, Name: "入门篇", Icon: "🌱", Chars: []Character{
			Character{"一", "yī", "数字1", "一个,一天,一起", "我有一本书。", "史蒂夫找到了一块钻石！"},
			Character{"二", "èr", "数字2", "二月,第二", "我有二本书。", "需要二个木棍做木剑。"},
			Character{"三", "sān", "数字3", "三个,三天", "三个苹果。", "三只僵尸在追我！"},
			Character{"十", "shí", "数字10", "十个,十天", "我有十块钱。", "挖了十个铁矿石。"},
			Character{"大", "dà", "Big", "大人,大山,大家", "这是一个大苹果。", "好大的一棵树！"},
			Character{"小", "xiǎo", "Small", "小鸟,小心,小朋友", "小猫很可爱。", "小心苦力怕！"},
			Character{"上", "shàng", "Up/On", "上面,上学,上山", "书在桌子上面。", "爬上山顶看日出。"},
			Character{"下", "xià", "Down", "下面,下雨,下山", "鞋子在床下面。", "下矿洞挖钻石！"},
		}},
		Course{Id: 1, Name: "自然篇", Icon: "🌲", Chars: []Character{
			Character{"山", "shān", "Mountain", "大山,上山,山洞", "远处有一座大山。", "我们在高山上建城堡。"},
			Character{"水", "shuǐ", "Water", "喝水,河水,水果", "我想喝水。", "小心别掉进水里！"},
			Character{"火", "huǒ", "Fire", "火车,火山,着火", "小心火！", "用打火石点燃火把。"},
			Character{"土", "tǔ", "Earth/Soil", "土地,泥土", "花长在土里。", "挖掉泥土找矿石。"},
			Character{"木", "mù", "Wood", "木头,树木,木棍", "这是木头做的。", "先砍树收集木头！"},
			Character{"石", "shí", "Stone", "石头,宝石", "河里有很多石头。", "用石头做石镐。"},
			Character{"天", "tiān", "Sky/Day", "蓝天,今天,天气", "今天天气很好。", "天黑了，僵尸出来了！"},
			Character{"日", "rì", "Sun/Day", "日出,生日,日记", "太阳升起来了。", "日出时怪物会燃烧。"},
			Character{"月", "yuè", "Moon", "月亮,月饼", "月亮好圆啊。", "满月时狼人会变身！"},
			Character{"云", "yún", "Cloud", "白云,云朵", "天上有白云。", "飞到云层上面去！"},
		}},
		Course{Id: 2, Name: "动物篇", Icon: "🐷", Chars: []Character{
			Character{"牛", "niú", "Cow", "牛奶,小牛", "牛在吃草。", "用小麦喂牛可以繁殖。"},
			Character{"羊", "yáng", "Sheep", "小羊,羊毛", "羊毛是白色的。", "剪羊毛做床！"},
			Character{"马", "mǎ", "Horse", "小马,马路", "马跑得很快。", "驯服一匹马当坐骑。"},
			Character{"鸟", "niǎo", "Bird", "小鸟,鸟窝", "小鸟会飞。", "鹦鹉可以当宠物！"},
			Character{"鱼", "yú", "Fish", "小鱼,鱼儿", "鱼在水里游。", "钓鱼可以获得食物。"},
			Character{"虫", "chóng", "Insect", "虫子,毛虫", "草丛里有虫子。", "蜘蛛会掉蜘蛛丝。"},
			Character{"猪", "zhū", "Pig", "小猪,猪肉", "小猪很可爱。", "猪排是重要的食物！"},
			Character{"狗", "gǒu", "Dog", "小狗,狗狗", "小狗很忠诚。", "驯服狼变成狗！"},
